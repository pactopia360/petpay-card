(() => {
    'use strict';

    const root = document.querySelector('[data-driver-dashboard]');

    if (!root) {
        return;
    }

    const csrfToken = document
        .querySelector('meta[name="csrf-token"]')
        ?.getAttribute('content');

    root.querySelectorAll('[data-driver-progress]').forEach((bar) => {
        const rawValue = Number.parseInt(
            bar.dataset.driverProgress || '0',
            10
        );

        const percentage = Number.isFinite(rawValue)
            ? Math.max(0, Math.min(100, rawValue))
            : 0;

        bar.style.width = `${percentage}%`;
    });

    const buttons = Array.from(
        root.querySelectorAll('[data-driver-tab-button]')
    );

    const panels = Array.from(
        root.querySelectorAll('[data-driver-tab-panel]')
    );

    const activateTab = (tab) => {
        buttons.forEach((button) => {
            button.classList.toggle(
                'is-active',
                button.dataset.driverTabButton === tab
            );
        });

        panels.forEach((panel) => {
            panel.classList.toggle(
                'is-active',
                panel.dataset.driverTabPanel === tab
            );
        });

        const url = new URL(window.location.href);

        url.searchParams.set('tab', tab);

        window.history.replaceState({}, '', url);
    };

    buttons.forEach((button) => {
        button.addEventListener('click', () => {
            activateTab(button.dataset.driverTabButton);
        });
    });

    root.querySelectorAll('input[name="curp"]').forEach((input) => {
        input.addEventListener('input', () => {
            input.value = input.value
                .toUpperCase()
                .replace(/[^A-Z0-9]/g, '')
                .slice(0, 18);
        });
    });

    root.querySelectorAll('input[type="tel"]').forEach((input) => {
        input.addEventListener('input', () => {
            input.value = input.value
                .replace(/[^\d+\-\s()]/g, '')
                .slice(0, 16);
        });
    });

    root.querySelectorAll('input[name="postal_code"]').forEach((input) => {
        input.addEventListener('input', () => {
            input.value = input.value
                .replace(/\D/g, '')
                .slice(0, 5);
        });
    });

    const phoneInput = root.querySelector('[data-driver-phone-input]');
    const requestButton = root.querySelector('[data-driver-phone-request]');
    const phoneStatus = root.querySelector('[data-driver-phone-status]');

    const modal = document.querySelector('[data-driver-phone-modal]');
    const modalMessage = modal?.querySelector(
        '[data-driver-phone-modal-message]'
    );
    const maskedPhone = modal?.querySelector(
        '[data-driver-phone-masked]'
    );
    const codeInput = modal?.querySelector(
        '[data-driver-phone-code]'
    );
    const feedback = modal?.querySelector(
        '[data-driver-phone-feedback]'
    );
    const confirmButton = modal?.querySelector(
        '[data-driver-phone-confirm]'
    );

    let verificationId = null;

    const showFeedback = (message, type = 'info') => {
        if (!feedback) {
            return;
        }

        feedback.hidden = false;
        feedback.textContent = message;
        feedback.dataset.type = type;
    };

    const clearFeedback = () => {
        if (!feedback) {
            return;
        }

        feedback.hidden = true;
        feedback.textContent = '';
        feedback.dataset.type = '';
    };

    const openModal = () => {
        if (!modal) {
            return;
        }

        modal.hidden = false;
        document.body.classList.add('driver-modal-open');

        window.setTimeout(() => {
            codeInput?.focus();
        }, 50);
    };

    const closeModal = () => {
        if (!modal) {
            return;
        }

        modal.hidden = true;
        document.body.classList.remove('driver-modal-open');
        clearFeedback();

        if (codeInput) {
            codeInput.value = '';
        }
    };

    modal
        ?.querySelectorAll('[data-driver-phone-close]')
        .forEach((button) => {
            button.addEventListener('click', closeModal);
        });

    requestButton?.addEventListener('click', async () => {
        const phone = phoneInput?.value.trim() || '';

        if (!/^(?:\+?52)?\d{10}$/.test(phone.replace(/\D/g, ''))) {
            window.alert(
                'Captura un teléfono válido de 10 dígitos.'
            );
            phoneInput?.focus();
            return;
        }

        requestButton.disabled = true;
        requestButton.textContent = 'Generando...';

        try {
            const response = await fetch(
                requestButton.dataset.requestUrl,
                {
                    method: 'POST',
                    headers: {
                        'Accept': 'application/json',
                        'Content-Type': 'application/json',
                        'X-CSRF-TOKEN': csrfToken || '',
                    },
                    body: JSON.stringify({
                        phone,
                    }),
                }
            );

            const data = await response.json();

            if (!response.ok || !data.ok) {
                throw new Error(
                    data.message ||
                    'No se pudo generar la verificación.'
                );
            }

            verificationId = data.verification_id;

            if (maskedPhone) {
                maskedPhone.textContent =
                    data.phone_masked || phone;
            }

            if (modalMessage) {
                modalMessage.textContent = data.message;
            }

            openModal();
        } catch (error) {
            window.alert(
                error.message ||
                'Ocurrió un error al solicitar el código.'
            );
        } finally {
            requestButton.disabled = false;
            requestButton.textContent = 'Verificar teléfono';
        }
    });

    codeInput?.addEventListener('input', () => {
        codeInput.value = codeInput.value
            .replace(/\D/g, '')
            .slice(0, 6);
    });

    confirmButton?.addEventListener('click', async () => {
        const code = codeInput?.value.trim() || '';

        if (!verificationId) {
            showFeedback(
                'Primero solicita un código.',
                'error'
            );
            return;
        }

        if (!/^\d{6}$/.test(code)) {
            showFeedback(
                'Captura el código completo de 6 dígitos.',
                'error'
            );
            codeInput?.focus();
            return;
        }

        confirmButton.disabled = true;
        confirmButton.textContent = 'Validando...';
        clearFeedback();

        const verifyUrl = requestButton.dataset.requestUrl
            .replace(
                '/solicitar',
                `/${verificationId}/confirmar`
            );

        try {
            const response = await fetch(
                verifyUrl,
                {
                    method: 'POST',
                    headers: {
                        'Accept': 'application/json',
                        'Content-Type': 'application/json',
                        'X-CSRF-TOKEN': csrfToken || '',
                    },
                    body: JSON.stringify({
                        code,
                    }),
                }
            );

            const data = await response.json();

            if (!response.ok || !data.ok) {
                throw new Error(
                    data.message ||
                    'No se pudo confirmar el código.'
                );
            }

            showFeedback(
                data.message,
                'success'
            );

            if (phoneStatus) {
                phoneStatus.textContent =
                    'Teléfono verificado correctamente.';
                phoneStatus.classList.add('is-verified');
            }

            requestButton.textContent = 'Verificado';
            requestButton.classList.add('is-verified');

            window.setTimeout(() => {
                closeModal();
            }, 900);
        } catch (error) {
            showFeedback(
                error.message ||
                'Código incorrecto.',
                'error'
            );
        } finally {
            confirmButton.disabled = false;
            confirmButton.textContent = 'Confirmar código';
        }
    });


    const addressCatalogs = {
