            'Roma Norte',
            'Roma Sur',
            'San Rafael',
            'Santa María la Ribera'
        ],
        'Benito Juárez': [
            'Del Valle Centro',
            'Del Valle Norte',
            'Del Valle Sur',
            'Narvarte',
            'Nápoles',
            'Portales',
            'San Pedro de los Pinos'
        ],
        'Guadalajara': [
            'Americana',
            'Arcos Vallarta',
            'Centro',
            'Chapalita',
            'Ladrón de Guevara',
            'Providencia'
        ],
        'Monterrey': [
            'Centro',
            'Cumbres',
            'Mitras Centro',
            'Obispado',
            'San Jerónimo',
            'Tecnológico'
        ]
    };

    const addressState = root.querySelector(
        '[data-driver-address-state]'
    );

    const municipalityInput = root.querySelector(
        '[data-driver-municipality]'
    );

    const cityInput = root.querySelector(
        '[data-driver-address-city]'
    );

    const neighborhoodInput = root.querySelector(
        '[data-driver-neighborhood]'
    );

    const municipalityOptions = root.querySelector(
        '[data-driver-municipality-options]'
    );

    const cityOptions = root.querySelector(
        '[data-driver-city-address-options]'
    );

    const neighborhoodOptions = root.querySelector(
        '[data-driver-neighborhood-options]'
    );

    const fillDatalist = (datalist, values) => {
        if (!datalist) {
            return;
        }

        datalist.innerHTML = '';

        values.forEach((value) => {
            const option = document.createElement('option');
            option.value = value;
            datalist.appendChild(option);
        });
    };

    const refreshAddressCatalogs = () => {
        const selectedState = addressState?.value || '';
        const municipalities = addressCatalogs[selectedState] || [];

        fillDatalist(municipalityOptions, municipalities);
        fillDatalist(cityOptions, municipalities);
    };

    const refreshNeighborhoodCatalog = () => {
        const municipality =
            municipalityInput?.value.trim() ||
            cityInput?.value.trim() ||
            '';

        fillDatalist(
            neighborhoodOptions,
            neighborhoodCatalogs[municipality] || []
        );
    };

    addressState?.addEventListener('change', () => {
        refreshAddressCatalogs();

        if (municipalityInput) {
            municipalityInput.value = '';
        }

        if (cityInput) {
            cityInput.value = '';
        }

        if (neighborhoodInput) {
            neighborhoodInput.value = '';
        }

        refreshNeighborhoodCatalog();
    });

    municipalityInput?.addEventListener(
        'change',
        refreshNeighborhoodCatalog
    );

    municipalityInput?.addEventListener(
        'input',
        refreshNeighborhoodCatalog
    );

    cityInput?.addEventListener(
        'change',
        refreshNeighborhoodCatalog
    );

    cityInput?.addEventListener(
        'input',
        refreshNeighborhoodCatalog
    );

    refreshAddressCatalogs();
    refreshNeighborhoodCatalog();

    const postalCodeInput = root.querySelector(
        '[data-driver-postal-code]'
    );

    const postalCodeMessage = root.querySelector(
        '[data-driver-postal-message]'
    );

    postalCodeInput?.addEventListener('input', () => {
        postalCodeInput.value = postalCodeInput.value
            .replace(/\D/g, '')
            .slice(0, 5);

        if (!postalCodeMessage) {
            return;
        }

        if (postalCodeInput.value.length === 5) {
            postalCodeMessage.textContent =
                'Código postal listo para validar.';
            postalCodeMessage.classList.add('is-valid');
        } else {
            postalCodeMessage.textContent =
                'Captura los 5 dígitos.';
            postalCodeMessage.classList.remove('is-valid');
        }
    });


    /*
     * ========================================================
     * REFERENCIAS PERSONALES:
     * SINCRONIZAR TIPO Y RELACION
     * ========================================================
     */

    const familyRelationshipCodes = new Set([
        'mother',
        'father',
        'stepmother',
        'stepfather',
        'sister',
        'brother',
        'spouse',
        'partner',
        'daughter',
        'son',
        'grandmother',
        'grandfather',
        'aunt',
        'uncle',
        'cousin_female',
        'cousin_male'
    ]);

    const nonFamilyRelationshipCodes = new Set([
        'friend_female',
        'friend_male',
        'neighbor_female',
        'neighbor_male',
        'coworker_female',
        'coworker_male',
        'boss_female',
        'boss_male',
        'client_female',
        'client_male'
    ]);

    const relationshipTypeForCode = (relationshipCode) => {
        if (familyRelationshipCodes.has(relationshipCode)) {
            return 'family';
        }

        if (nonFamilyRelationshipCodes.has(relationshipCode)) {
            return 'non_family';
        }

        return '';
    };

    const configureReferenceBlock = (referenceBlock) => {
        const typeSelect = referenceBlock.querySelector(
            '[data-reference-type]'
        );

        const relationshipSelect = referenceBlock.querySelector(
            '[data-reference-relationship]'
        );

        if (!typeSelect || !relationshipSelect) {
            return;
        }

        const allOptions = Array.from(
            relationshipSelect.options
        );

        const filterRelationshipOptions = ({
            clearIncompatible = false
        } = {}) => {
            const selectedType = typeSelect.value;
            const selectedRelationship = relationshipSelect.value;

            allOptions.forEach((option) => {
                if (!option.value) {
                    option.hidden = false;
                    option.disabled = false;
                    return;
                }

                const optionType = relationshipTypeForCode(
                    option.value
                );

                const isCompatible =
                    !selectedType
                    || option.value === 'other'
                    || optionType === selectedType;

                option.hidden = !isCompatible;
                option.disabled = !isCompatible;
            });

            if (
                clearIncompatible
                && selectedRelationship
                && selectedRelationship !== 'other'
                && relationshipTypeForCode(selectedRelationship)
                    !== selectedType
            ) {
                relationshipSelect.value = '';
            }
        };

        const synchronizeTypeFromRelationship = () => {
            const relationshipCode = relationshipSelect.value;

            if (!relationshipCode) {
                filterRelationshipOptions();
                return;
            }

            if (relationshipCode === 'other') {
                filterRelationshipOptions();
                return;
            }

            const expectedType = relationshipTypeForCode(
                relationshipCode
            );

            if (expectedType) {
                typeSelect.value = expectedType;
            }

            filterRelationshipOptions();
        };

        typeSelect.addEventListener('change', () => {
            filterRelationshipOptions({
                clearIncompatible: true
            });

            relationshipSelect.focus();
        });

        relationshipSelect.addEventListener(
            'change',
            synchronizeTypeFromRelationship
        );

        /*
         * Si ya existe una relación guardada o recuperada con old(),
         * la relación es la fuente principal y corrige el tipo.
         */
        if (
            relationshipSelect.value
            && relationshipSelect.value !== 'other'
        ) {
            synchronizeTypeFromRelationship();
        } else {
            filterRelationshipOptions({
                clearIncompatible: true
            });
        }
    };

    root
        .querySelectorAll('[data-driver-reference]')
        .forEach(configureReferenceBlock);


    /*
     * ========================================================
     * DISEÑO DEL SOCIO:
     * REORGANIZAR EXPEDIENTE Y DOCUMENTACION
     * ========================================================
     */

    const userPanel = root.querySelector(
        '[data-driver-tab-panel="usuario"]'
    );

    const normalizedText = (value) => {
        return String(value || '')
            .normalize('NFD')
            .replace(/[\u0300-\u036f]/g, '')
            .trim()
            .toLowerCase();
    };

    const findHeading = (title) => {
        const normalizedTitle = normalizedText(title);

        return Array.from(
            userPanel?.querySelectorAll(
                '.driver-section-heading'
            ) || []
        ).find((heading) => {
            return normalizedText(
                heading.querySelector('h2')?.textContent
            ) === normalizedTitle;
        });
    };

    const createModule = ({
        title,
        subtitle,
        icon,
        state = 'Pendiente',
        open = false,
        modifier = ''
    }) => {
        const details = document.createElement('details');

        details.className =
            `driver-partner-module ${modifier}`.trim();

        details.open = open;

        const summary = document.createElement('summary');

        summary.className = 'driver-partner-module__summary';

        const identity = document.createElement('div');

        identity.className = 'driver-partner-module__identity';

        const iconElement = document.createElement('span');

        iconElement.className = 'driver-partner-module__icon';
        iconElement.setAttribute('aria-hidden', 'true');
        iconElement.textContent = icon;

        const text = document.createElement('div');

        text.className = 'driver-partner-module__text';

        const strong = document.createElement('strong');

        strong.textContent = title;

        const small = document.createElement('small');

        small.textContent = subtitle || '';

        text.append(strong);

        if (subtitle) {
            text.append(small);
        }

        identity.append(iconElement, text);

        const actions = document.createElement('div');

        actions.className = 'driver-partner-module__actions';

        const badge = document.createElement('span');

        badge.className = 'driver-partner-module__state';
        badge.textContent = state;

        const arrow = document.createElement('span');

        arrow.className = 'driver-partner-module__arrow';
        arrow.setAttribute('aria-hidden', 'true');
        arrow.textContent = '⌃';

        actions.append(badge, arrow);
        summary.append(identity, actions);

        const body = document.createElement('div');

        body.className = 'driver-partner-module__body';

        details.append(summary, body);

        return {
            details,
            body,
            badge
        };
    };

    const hasFilledFormValues = (container) => {
        if (!container) {
            return false;
        }

        return Array.from(
            container.querySelectorAll(
                'input:not([type="hidden"]):not([type="checkbox"]), select'
            )
        ).some((field) => {
            return String(field.value || '').trim() !== '';
        });
    };

    /*
     * Resumen del preregistro en acordeón compacto.
     */
    const preregistration = userPanel?.querySelector(
        '.driver-preregister'
    );

    if (
        preregistration
        && !preregistration.closest(
            '.driver-preregister-shell'
        )
    ) {
        const preregistrationShell =
            document.createElement('details');

        preregistrationShell.className =
            'driver-preregister-shell';

        const preregistrationSummary =
            document.createElement('summary');

        preregistrationSummary.innerHTML = `
            <span class="driver-preregister-shell__icon">✓</span>
            <span>
                <strong>Resumen de tu expediente</strong>
                <small>
                    Información recuperada del preregistro y avance actual.
                </small>
            </span>
            <b>
                ${
                    preregistration
                        .querySelector(
                            '.driver-progress-summary strong'
                        )
                        ?.textContent
                        ?.trim() || '0%'
                }
            </b>
        `;

        preregistration.parentNode.insertBefore(
            preregistrationShell,
            preregistration
        );

        preregistrationShell.append(
            preregistrationSummary,
            preregistration
        );
    }

    /*
     * Localizar las secciones actuales antes de moverlas.
     */
    const emergencyHeading = findHeading(
        'Contactos de emergencia'
    );

    const referencesHeading = findHeading(
        'Referencias personales'
    );

    const documentsHeading = findHeading(
        'Documentación personal'
    );

    const emergencyForm =
        emergencyHeading?.nextElementSibling?.matches('form')
            ? emergencyHeading.nextElementSibling
            : null;

    const referencesForm =
        referencesHeading?.nextElementSibling?.matches('form')
            ? referencesHeading.nextElementSibling
            : null;

    const documentList =
        documentsHeading?.nextElementSibling?.matches(
            '.driver-doc-list'
        )
            ? documentsHeading.nextElementSibling
            : null;

    const submitBox =
        documentList?.nextElementSibling?.matches(
            '.driver-submit-box'
        )
            ? documentList.nextElementSibling
            : null;

    if (
        documentsHeading
        && documentList
        && !userPanel.querySelector(
            '.driver-partner-documentation'
        )
    ) {
        const documentation = document.createElement(
            'section'
        );

        documentation.className =
            'driver-partner-documentation';

        documentation.innerHTML = `
            <div class="driver-partner-documentation__heading">
                <h2>Documentación personal</h2>
                <p>
                    Completa, revisa y actualiza cada apartado de tu expediente.
                </p>
            </div>
        `;

        documentsHeading.parentNode.insertBefore(
            documentation,
            documentsHeading
        );

        documentsHeading.remove();

        const modules = document.createElement('div');

        modules.className =
            'driver-partner-documentation__modules';

        documentation.append(modules);

        const documentItems = Array.from(
            documentList.querySelectorAll(
                '.driver-doc-item'
            )
        );

        /*
         * Agrupar INE frente y reverso.
         */
        const ineItems = documentItems.filter((item) => {
            const title = normalizedText(
                item.querySelector(
                    '.driver-doc-item__head strong'
                )?.textContent
            );

            return title.includes('ine frente')
                || title.includes('ine reverso');
        });

        if (ineItems.length > 0) {
            const approved = ineItems.every((item) => {
                return Boolean(
                    item.querySelector(
                        '.driver-badge--approved'
                    )
                );
            });

            const loaded = ineItems.every((item) => {
                return item.dataset.hasDocument === '1';
            });

            const hasError = ineItems.some((item) => {
                return item.dataset.analysisStatus === 'failed';
            });

            const needsReview = ineItems.some((item) => {
                return item.dataset.analysisStatus === 'manual_review';
            });

            const module = createModule({
                title: 'INE',
                subtitle:
                    'Identificación oficial por ambos lados.',
                icon: '▣',
                state: approved
                    ? 'Aprobado'
                    : hasError
                        ? 'Error IA'
                        : needsReview
                            ? 'Revisar'
                            : loaded
                                ? 'Cargado'
                                : 'Pendiente',
                open: true,
                modifier: approved
                    ? 'is-complete'
                    : hasError
                        ? 'is-error'
                        : needsReview
                            ? 'is-review'
                            : loaded
                                ? 'is-captured'
                                : ''
            });

            const ineGrid = document.createElement('div');

            ineGrid.className =
                'driver-partner-document-grid driver-partner-document-grid--2';

            ineItems.forEach((item) => {
                item.classList.add(
                    'driver-doc-item--embedded'
                );

                ineGrid.append(item);
            });

            module.body.append(ineGrid);
            modules.append(module.details);
        }

        /*
         * Convertir el resto de documentos a módulos.
         */
        documentItems
            .filter((item) => !ineItems.includes(item))
            .forEach((item, index) => {
                const title =
                    item.querySelector(
                        '.driver-doc-item__head strong'
                    )?.textContent
                    ?.trim() || 'Documento';

                const approved = Boolean(
                    item.querySelector(
                        '.driver-badge--approved'
                    )
                );

                const rejected = Boolean(
                    item.querySelector(
                        '.driver-badge--rejected'
                    )
                );

                const loaded =
                    item.dataset.hasDocument === '1';

                const analysisStatus =
                    item.dataset.analysisStatus || 'pending';

                const hasError =
                    analysisStatus === 'failed';

                const needsReview =
                    analysisStatus === 'manual_review';

                let icon = '▤';

                if (
                    normalizedText(title).includes(
                        'domicilio'
                    )
                ) {
                    icon = '⌂';
                } else if (
                    normalizedText(title).includes(
                        'licencia'
                    )
                ) {
                    icon = '▥';
                } else if (
                    normalizedText(title).includes('curp')
                ) {
                    icon = '▧';
                } else if (
                    normalizedText(title).includes(
                        'selfie'
                    )
                ) {
                    icon = '◉';
                }

                const module = createModule({
                    title,
                    subtitle: loaded
                        ? 'Documento almacenado en tu expediente.'
                        : 'Carga PDF, JPG, PNG o WEBP.',
                    icon,
                    state: approved
                        ? 'Aprobado'
                        : rejected
                            ? 'Corregir'
                            : hasError
                                ? 'Error IA'
                                : needsReview
                                    ? 'Revisar'
                                    : loaded
                                        ? 'Cargado'
                                        : 'Pendiente',
                    open: index === 0,
                    modifier: approved
                        ? 'is-complete'
                        : rejected
                            ? 'is-rejected'
                            : hasError
                                ? 'is-error'
                                : needsReview
                                    ? 'is-review'
                                    : loaded
                                        ? 'is-captured'
                                        : ''
                });

                item.classList.add(
                    'driver-doc-item--embedded'
                );

                module.body.append(item);
                modules.append(module.details);
            });

        /*
         * Contactos de emergencia dentro de documentación.
         */
        if (emergencyHeading && emergencyForm) {
            const completedContacts =
                hasFilledFormValues(emergencyForm);

            const module = createModule({
                title: 'Contactos de emergencia',
                subtitle:
                    'Registra de dos a cuatro personas.',
                icon: '☎',
                state: completedContacts
                    ? 'Capturado'
                    : 'Pendiente',
                open: false,
                modifier: completedContacts
                    ? 'is-captured'
                    : ''
            });

            emergencyHeading.classList.add(
                'driver-section-heading--inside-module'
            );

            module.body.append(
                emergencyHeading,
                emergencyForm
            );

            modules.append(module.details);
        }

        /*
         * Referencias personales dentro de documentación.
         */
        if (referencesHeading && referencesForm) {
            const completedReferences =
                hasFilledFormValues(referencesForm);

            const module = createModule({
                title: 'Referencias personales',
                subtitle:
                    'Referencias familiares y no familiares.',
                icon: '♧',
                state: completedReferences
                    ? 'Capturado'
                    : 'Pendiente',
                open: false,
                modifier: completedReferences
                    ? 'is-captured'
                    : ''
            });

            referencesHeading.classList.add(
                'driver-section-heading--inside-module'
            );

            module.body.append(
                referencesHeading,
                referencesForm
            );

            modules.append(module.details);
        }

        documentList.remove();

        if (submitBox) {
            documentation.append(submitBox);
        }
    }

    /*
     * Mostrar nombre del archivo seleccionado.
     */
    root
        .querySelectorAll(
            '.driver-upload-form input[type="file"]'
        )
        .forEach((input) => {
            input.addEventListener('change', () => {
                const form = input.closest(
                    '.driver-upload-form'
                );

                let selectedName = form?.querySelector(
                    '.driver-upload-selected-name'
                );

                if (!selectedName && form) {
                    selectedName =
                        document.createElement('span');

                    selectedName.className =
                        'driver-upload-selected-name';

                    form.append(selectedName);
                }

                if (selectedName) {
                    selectedName.textContent =
                        input.files?.[0]?.name
                        || 'Sin archivo seleccionado';
                }
            });
        });

    root.querySelectorAll('.driver-upload-form').forEach((form) => {
        const input = form.querySelector('input[type="file"]');
        const button = form.querySelector('button[type="submit"]');

        form.addEventListener('submit', (event) => {
            if (!input || !input.files || input.files.length === 0) {
                event.preventDefault();
                window.alert(
                    'Selecciona un archivo antes de continuar.'
                );
                return;
            }

            if (button) {
                button.disabled = true;
                button.textContent = 'Cargando...';
            }
        });
    });

    document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
            closeModal();

            document
                .querySelectorAll('[data-driver-account-menu][open]')
                .forEach((menu) => {
                    menu.open = false;
                });
        }
    });

    /*
     * ========================================================
     * PETPAY DOCUMENTOS IA Y CAMARA
     * ========================================================
     */

    const documentModal = document.querySelector(
        '[data-driver-document-modal]'
    );

    const documentModalTitle = documentModal?.querySelector(
        '[data-driver-document-modal-title]'
    );

    const documentViewer = documentModal?.querySelector(
        '[data-driver-document-viewer]'
    );

    const cameraModal = document.querySelector(
        '[data-driver-camera-modal]'
    );

    const cameraTitle = cameraModal?.querySelector(
        '[data-driver-camera-title]'
    );

    const cameraVideo = cameraModal?.querySelector(
        '[data-driver-camera-video]'
    );

    const cameraCanvas = cameraModal?.querySelector(
        '[data-driver-camera-canvas]'
    );

    const cameraMessage = cameraModal?.querySelector(
        '[data-driver-camera-message]'
    );

    const cameraCapture = cameraModal?.querySelector(
        '[data-driver-camera-capture]'
    );

    let activeCameraInput = null;
    let activeCameraStream = null;

    const escapeHtml = (value) => {
        const element = document.createElement('div');
        element.textContent = String(value ?? '');
        return element.innerHTML;
    };

    const humanFileSize = (bytes) => {
        if (!Number.isFinite(bytes) || bytes <= 0) {
            return '0 KB';
        }

        const units = ['B', 'KB', 'MB', 'GB'];
        const index = Math.min(
            Math.floor(Math.log(bytes) / Math.log(1024)),
            units.length - 1
        );

        return `${(bytes / Math.pow(1024, index)).toFixed(
            index === 0 ? 0 : 1
        )} ${units[index]}`;
    };

    const closeDocumentModal = () => {
        if (!documentModal) {
            return;
        }

        documentModal.hidden = true;

        if (documentViewer) {
            documentViewer.innerHTML = '';
        }

        document.body.classList.remove('driver-modal-open');
    };

    const openDocumentModal = ({
        url,
        mime,
        title
    }) => {
        if (!documentModal || !documentViewer || !url) {
            return;
        }

        documentViewer.innerHTML = '';

        if (documentModalTitle) {
            documentModalTitle.textContent =
                title || 'Vista previa';
        }

        if (String(mime).startsWith('image/')) {
            const image = document.createElement('img');
            image.src = url;
            image.alt = title || 'Documento';
            documentViewer.append(image);
        } else {
            const frame = document.createElement('iframe');
            frame.src = url;
            frame.title = title || 'Documento';
            documentViewer.append(frame);
        }

        documentModal.hidden = false;
        document.body.classList.add('driver-modal-open');
    };

    root
        .querySelectorAll('[data-driver-preview-open]')
        .forEach((button) => {
            button.addEventListener('click', () => {
                openDocumentModal({
                    url: button.dataset.previewUrl,
                    mime: button.dataset.previewMime,
                    title: button.dataset.previewTitle
                });
            });
        });

    documentModal
        ?.querySelectorAll('[data-driver-document-modal-close]')
        .forEach((button) => {
            button.addEventListener(
                'click',
                closeDocumentModal
            );
        });

    const stopCamera = () => {
        if (activeCameraStream) {
            activeCameraStream
                .getTracks()
                .forEach((track) => track.stop());
        }

        activeCameraStream = null;

        if (cameraVideo) {
            cameraVideo.srcObject = null;
        }
    };

    const closeCameraModal = () => {
        stopCamera();

        if (cameraModal) {
            cameraModal.hidden = true;
        }

        activeCameraInput = null;
        document.body.classList.remove('driver-modal-open');
    };

    cameraModal
        ?.querySelectorAll('[data-driver-camera-close]')
        .forEach((button) => {
            button.addEventListener(
                'click',
                closeCameraModal
            );
        });

    root
        .querySelectorAll('[data-driver-camera-open]')
        .forEach((button) => {
            button.addEventListener('click', async () => {
                const form = button.closest(
                    '[data-driver-document-upload]'
                );

                const input = form?.querySelector(
                    '[data-driver-document-input]'
                );

                if (!input) {
                    return;
                }

                if (
                    !navigator.mediaDevices
                    || !navigator.mediaDevices.getUserMedia
                ) {
                    window.alert(
                        'Este navegador no permite abrir la cámara. Usa Seleccionar archivo.'
                    );
                    return;
                }

                activeCameraInput = input;

                if (cameraTitle) {
                    cameraTitle.textContent =
                        button.dataset.documentLabel
                        || 'Tomar fotografía';
                }

                if (cameraMessage) {
                    cameraMessage.textContent =
                        button.dataset.facingMode === 'user'
                            ? 'Centra tu rostro, mira al frente y procura tener buena iluminación.'
                            : 'Centra el documento completo, evita reflejos y mantén la cámara firme.';
                }

                try {
                    activeCameraStream =
                        await navigator.mediaDevices.getUserMedia({
                            video: {
                                facingMode: {
                                    ideal:
                                        button.dataset.facingMode
                                        || 'environment'
                                },
                                width: {
                                    ideal: 1920
                                },
                                height: {
                                    ideal: 1080
                                }
                            },
                            audio: false
                        });

                    if (cameraVideo) {
                        cameraVideo.srcObject =
                            activeCameraStream;
                    }

                    if (cameraModal) {
                        cameraModal.hidden = false;
                    }

                    document.body.classList.add(
                        'driver-modal-open'
                    );
                } catch (error) {
                    stopCamera();

                    window.alert(
                        'No fue posible abrir la cámara. Revisa los permisos del navegador.'
                    );
                }
            });
        });

    const updateLocalPreview = (input, file) => {
        const card = input.closest(
            '[data-driver-document-card]'
        );

        const preview = card?.querySelector(
            '[data-driver-document-preview]'
        );

        const selectedName = card?.querySelector(
            '[data-driver-selected-file]'
        );

        if (selectedName) {
            selectedName.textContent =
                `${file.name} · ${humanFileSize(file.size)}`;
        }

        if (!preview) {
            return;
        }

        preview.innerHTML = '';
        preview.classList.add('has-document');

        const objectUrl = URL.createObjectURL(file);

        if (file.type.startsWith('image/')) {
            const button = document.createElement('button');
            button.type = 'button';
            button.className =
                'driver-document-preview__button';

            const image = document.createElement('img');
            image.src = objectUrl;
            image.alt = file.name;

            button.append(image);

            button.addEventListener('click', () => {
                openDocumentModal({
                    url: objectUrl,
                    mime: file.type,
                    title: file.name
                });
            });

            preview.append(button);
            return;
        }

        const button = document.createElement('button');
        button.type = 'button';
        button.className =
            'driver-document-preview__pdf';

        button.innerHTML = `
            <span>PDF</span>
            <strong>${escapeHtml(file.name)}</strong>
            <small>${humanFileSize(file.size)}</small>
        `;

        button.addEventListener('click', () => {
            openDocumentModal({
                url: objectUrl,
                mime: file.type,
                title: file.name
            });
        });

        preview.append(button);
    };

    root
        .querySelectorAll('[data-driver-document-input]')
        .forEach((input) => {
            input.addEventListener('change', () => {
                const file = input.files?.[0];

                if (!file) {
                    return;
                }

                const allowedTypes = [
                    'application/pdf',
                    'image/jpeg',
                    'image/png',
                    'image/webp'
                ];

                if (!allowedTypes.includes(file.type)) {
                    input.value = '';

                    window.alert(
                        'Formato no permitido. Usa PDF, JPG, PNG o WEBP.'
                    );
                    return;
                }

                if (file.size > 10 * 1024 * 1024) {
                    input.value = '';

                    window.alert(
                        'El archivo excede el límite de 10 MB.'
                    );
                    return;
                }

                updateLocalPreview(input, file);
            });
        });

    cameraCapture?.addEventListener('click', () => {
        if (
            !cameraVideo
            || !cameraCanvas
            || !activeCameraInput
        ) {
            return;
        }

        const width = cameraVideo.videoWidth;
        const height = cameraVideo.videoHeight;

        if (!width || !height) {
            window.alert(
                'La cámara todavía no está lista.'
            );
            return;
        }

        cameraCanvas.width = width;
        cameraCanvas.height = height;

        const context = cameraCanvas.getContext('2d');

        context.drawImage(
            cameraVideo,
            0,
            0,
            width,
            height
        );

        cameraCanvas.toBlob(
            (blob) => {
                if (!blob) {
                    window.alert(
                        'No fue posible crear la fotografía.'
                    );
                    return;
                }

                const documentType =
                    activeCameraInput
                        .closest(
                            '[data-driver-document-card]'
                        )
                        ?.dataset.documentType
                    || 'documento';

                const file = new File(
                    [blob],
                    `${documentType}-${Date.now()}.jpg`,
                    {
                        type: 'image/jpeg',
                        lastModified: Date.now()
                    }
                );

                const transfer = new DataTransfer();
                transfer.items.add(file);

                activeCameraInput.files = transfer.files;

                updateLocalPreview(
                    activeCameraInput,
                    file
                );

                closeCameraModal();
            },
            'image/jpeg',
            0.92
        );
    });


    const updateModal = document.querySelector(
        '[data-driver-update-modal]'
    );

    const openUpdateModal = () => {
        if (!updateModal) {
            return;
        }

        updateModal.hidden = false;
        document.body.classList.add('driver-modal-open');

        updateModal
            .querySelector('select, input, textarea')
            ?.focus();
    };

    const closeUpdateModal = () => {
        if (!updateModal) {
            return;
        }

        updateModal.hidden = true;
        document.body.classList.remove('driver-modal-open');
    };

    document
        .querySelectorAll('[data-driver-update-request-open]')
        .forEach((button) => {
            button.addEventListener('click', openUpdateModal);
        });

    document
        .querySelectorAll('[data-driver-update-request-close]')
        .forEach((button) => {
            button.addEventListener('click', closeUpdateModal);
        });

    document.addEventListener('keydown', (event) => {
        if (
            event.key === 'Escape'
            && updateModal
            && !updateModal.hidden
        ) {
            closeUpdateModal();
        }
    });

})();

