/* PETPAY COMERCIO CATALOGOS */

.commerce-catalog {
    display: grid;
    gap: 18px;
}

.commerce-catalog__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 16px;
}

.commerce-catalog__header h2 {
    margin: 0;
    color: #334155;
    font-size: 20px;
}

.commerce-catalog__header p {
    margin: 4px 0 0;
    color: #64748b;
    font-size: 13px;
}

.commerce-catalog__kpis {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
}

.commerce-catalog__kpi,
.commerce-catalog__block,
.commerce-catalog__product {
    border: 1px solid rgba(15, 23, 42, .10);
    background: rgba(255, 255, 255, .76);
    box-shadow: 0 18px 42px rgba(15, 23, 42, .08);
    backdrop-filter: blur(12px);
}

.commerce-catalog__kpi {
    padding: 14px;
    border-radius: 16px;
}

.commerce-catalog__kpi span {
    display: block;
    color: #64748b;
    font-size: 11px;
    font-weight: 900;
}

.commerce-catalog__kpi strong {
    display: block;
    margin-top: 5px;
    color: #111827;
    font-size: 24px;
}

.commerce-catalog__block {
    padding: 18px;
    border-radius: 22px;
}

.commerce-catalog__block-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    margin-bottom: 14px;
}

.commerce-catalog__block-head h3 {
    margin: 0;
    color: #1f2937;
    font-size: 17px;
}

.commerce-catalog__block-head p {
    margin: 4px 0 0;
    color: #64748b;
    font-size: 12px;
}

.commerce-catalog__mini-grid {
    display: grid;
    grid-template-columns: 1.2fr 1.2fr auto;
    gap: 10px;
    align-items: end;
}

.commerce-catalog__form-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
}

.commerce-catalog__form-grid--wide {
    grid-template-columns: repeat(2, minmax(0, 1fr));
}

.commerce-catalog__field {
    display: grid;
    gap: 5px;
    min-width: 0;
}

.commerce-catalog__field span {
    color: #334155;
    font-size: 11px;
    font-weight: 900;
}

.commerce-catalog__field input,
.commerce-catalog__field select,
.commerce-catalog__field textarea {
    width: 100%;
    min-height: 40px;
    border: 1px solid rgba(15, 23, 42, .14);
    border-radius: 11px;
    background: rgba(255,255,255,.94);
    padding: 9px 10px;
    color: #111827;
    font: inherit;
    font-size: 12px;
    outline: none;
}

.commerce-catalog__field textarea {
    min-height: 86px;
    resize: vertical;
}

.commerce-catalog__field input:focus,
.commerce-catalog__field select:focus,
.commerce-catalog__field textarea:focus {
    border-color: rgba(249, 115, 22, .62);
    box-shadow: 0 0 0 4px rgba(249, 115, 22, .11);
}

.commerce-catalog__check {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-height: 40px;
    color: #334155;
    font-size: 12px;
    font-weight: 850;
}

.commerce-catalog__button {
    min-height: 40px;
    padding: 0 15px;
    border: 0;
    border-radius: 11px;
    background: #111827;
    color: #fff;
    font-weight: 900;
    cursor: pointer;
}

.commerce-catalog__button--soft {
    background: #fff7ed;
    color: #9a3412;
    border: 1px solid rgba(249,115,22,.22);
}

.commerce-catalog__button--danger {
    background: rgba(239,68,68,.10);
    color: #b91c1c;
    border: 1px solid rgba(239,68,68,.18);
}

.commerce-catalog__tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 12px;
}

.commerce-catalog__tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    min-height: 28px;
    padding: 0 10px;
    border-radius: 999px;
    background: rgba(15,23,42,.07);
    color: #475569;
    font-size: 11px;
    font-weight: 850;
}

.commerce-catalog__stock-grid {
    display: grid;
    gap: 10px;
    margin-top: 14px;
}

.commerce-catalog__stock-row {
    display: grid;
    grid-template-columns: minmax(160px, 1fr) 120px 120px 110px;
    gap: 10px;
    align-items: end;
    padding: 10px;
    border-radius: 14px;
    background: rgba(15,23,42,.035);
}

.commerce-catalog__stock-row strong {
    color: #334155;
    font-size: 12px;
}

.commerce-catalog__toolbar {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 180px 180px;
    gap: 10px;
    margin-bottom: 14px;
}

.commerce-catalog__products {
    display: grid;
    gap: 12px;
}

.commerce-catalog__product {
    display: grid;
    grid-template-columns: 86px minmax(0, 1fr) 150px 140px;
    gap: 14px;
    align-items: center;
    padding: 13px;
    border-radius: 18px;
}

.commerce-catalog__product[hidden] {
    display: none !important;
}

.commerce-catalog__product-image {
    width: 86px;
    height: 86px;
    border-radius: 14px;
    overflow: hidden;
    background: rgba(15,23,42,.06);
    display: grid;
    place-items: center;
    color: #94a3b8;
    font-weight: 900;
}

.commerce-catalog__product-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.commerce-catalog__product h4 {
    margin: 0;
    color: #111827;
    font-size: 15px;
}

.commerce-catalog__product p {
    margin: 4px 0 0;
    color: #64748b;
    font-size: 11px;
}

.commerce-catalog__price {
    color: #111827;
    font-size: 15px;
    font-weight: 950;
}

.commerce-catalog__price small {
    display: block;
    color: #64748b;
    font-size: 10px;
    font-weight: 700;
}

.commerce-catalog__actions {
    display: flex;
    justify-content: flex-end;
    gap: 7px;
}

.commerce-catalog__icon {
    width: 36px;
    height: 36px;
    display: inline-grid;
    place-items: center;
    border: 1px solid rgba(15,23,42,.12);
    border-radius: 11px;
    background: #fff;
    color: #334155;
    cursor: pointer;
}

.commerce-catalog__icon svg {
    width: 17px;
    height: 17px;
    stroke: currentColor;
}

.commerce-catalog__empty {
    padding: 24px;
    text-align: center;
    color: #64748b;
    border: 1px dashed rgba(15,23,42,.18);
    border-radius: 16px;
}

@media (max-width: 960px) {
    .commerce-catalog__kpis,
    .commerce-catalog__form-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .commerce-catalog__product {
        grid-template-columns: 72px minmax(0, 1fr);
    }

    .commerce-catalog__price,
    .commerce-catalog__actions {
        grid-column: 2;
    }
}

@media (max-width: 640px) {
    .commerce-catalog__kpis,
    .commerce-catalog__form-grid,
    .commerce-catalog__form-grid--wide,
    .commerce-catalog__mini-grid,
    .commerce-catalog__toolbar,
    .commerce-catalog__stock-row {
        grid-template-columns: 1fr;
    }

    .commerce-catalog__product {
        grid-template-columns: 1fr;
    }

    .commerce-catalog__product-image {
        width: 100%;
        height: 180px;
    }

    .commerce-catalog__price,
    .commerce-catalog__actions {
        grid-column: 1;
    }
}
