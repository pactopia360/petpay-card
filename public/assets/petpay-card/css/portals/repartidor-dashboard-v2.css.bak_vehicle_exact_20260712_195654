:root{
    --driver-bg:#f5f0e4;
    --driver-surface:#fffdf8;
    --driver-surface-soft:#f8f3e8;
    --driver-text:#001b44;
    --driver-muted:#727782;
    --driver-line:#d7d2c7;
    --driver-line-dark:#a5a5a5;
    --driver-blue:#4e95d9;
    --driver-blue-dark:#215f9a;
    --driver-green:#2a9d8f;
    --driver-green-soft:#e6f6ef;
    --driver-yellow:#d97706;
    --driver-yellow-soft:#fff3d8;
    --driver-red:#d62828;
    --driver-black:#121212;
    --driver-radius:8px;
    --driver-shadow:0 12px 35px rgba(29,35,42,.07);
}

*{
    box-sizing:border-box;
}

html,
body,
.petpay-page-repartidor{
    background:var(--driver-bg)!important;
}

body{
    color:var(--driver-text);
}

.petpay-page-repartidor .petpay-main{
    width:100%;
    max-width:none;
    padding:0;
}

/* =========================================================
   HEADER NEGRO
   ========================================================= */

.driver-black-header{
    position:sticky;
    top:0;
    z-index:100;
    height:58px;
    background:var(--driver-black);
    color:#fff;
}

.driver-black-header__inner{
    width:min(1100px,calc(100vw - 32px));
    height:100%;
    margin:auto;
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:20px;
}

.driver-black-header__brand,
.driver-black-header__right{
    display:flex;
    align-items:center;
    gap:10px;
}

.driver-black-header__brand{
    color:#fff;
    text-decoration:none;
}

.driver-black-header__brand img{
    width:38px;
    height:38px;
    object-fit:contain;
}

.driver-black-header__brand span,
.driver-black-header__identity,
.driver-black-header__menu-identity{
    display:grid;
    gap:1px;
}

.driver-black-header strong{
    font-size:12px;
}

.driver-black-header small{
    color:rgba(255,255,255,.63);
    font-size:9px;
}

.driver-black-header__identity{
    text-align:right;
}

.driver-black-header__account{
    position:relative;
}

.driver-black-header__logo-button{
    width:38px;
    height:38px;
    display:grid;
    place-items:center;
    padding:0;
    border:0;
    border-radius:50%;
    background:#fff;
    cursor:pointer;
    list-style:none;
}

.driver-black-header__logo-button::-webkit-details-marker{
    display:none;
}

.driver-black-header__logo-button img{
    width:30px;
    height:30px;
}

.driver-black-header__menu{
    position:absolute;
    top:47px;
    right:0;
    min-width:210px;
    padding:8px;
    border:1px solid var(--driver-line);
    border-radius:12px;
    background:var(--driver-surface);
    color:var(--driver-text);
    box-shadow:0 22px 50px rgba(0,0,0,.20);
}

.driver-black-header__menu-identity{
    padding:10px;
    border-bottom:1px solid var(--driver-line);
}

.driver-black-header__menu a,
.driver-black-header__menu button{
    display:block;
    width:100%;
    padding:10px;
    border:0;
    border-radius:7px;
    background:transparent;
    color:var(--driver-text);
    font:inherit;
    font-size:12px;
    font-weight:600;
    text-align:left;
    text-decoration:none;
    cursor:pointer;
}

.driver-black-header__menu a:hover,
.driver-black-header__menu button:hover{
    background:#eee8dc;
}

.driver-black-header__menu form{
    margin:0;
}

/* =========================================================
   CONTENEDOR GENERAL
   ========================================================= */

.driver-admin{
    width:min(1100px,calc(100vw - 32px));
    margin:auto;
    padding:28px 0 80px;
}

.driver-admin__hero{
    height:152px;
    margin:0 0 42px;
    border-radius:14px;
    overflow:hidden;
}

.driver-admin__hero img{
    width:100%;
    height:100%;
    object-fit:cover;
    object-position:center center;
}

.driver-admin__title{
    display:grid;
    grid-template-columns:minmax(0,1fr) minmax(340px,470px);
    align-items:start;
    gap:45px;
    margin-bottom:50px;
}

.driver-admin__title h1{
    margin:0;
    color:#4b535f;
    font-size:40px;
    font-weight:700;
    line-height:1.04;
    letter-spacing:-1.7px;
}

.driver-admin__title p{
    margin:5px 0 0;
    color:#4f5865;
    font-size:20px;
    font-weight:300;
    line-height:1.3;
    letter-spacing:-.8px;
}

.driver-admin__welcome{
    text-align:right;
}

.driver-admin__welcome strong{
    display:block;
    color:#3f3f3f;
    font-size:36px;
    font-weight:800;
    line-height:1;
    letter-spacing:-1.5px;
}

.driver-admin__welcome span{
    display:block;
    margin-top:8px;
    color:#4f5865;
    font-size:18px;
    font-weight:300;
    line-height:1.25;
    letter-spacing:-.7px;
}

/* =========================================================
   ALERTAS
   ========================================================= */

.driver-alert{
    margin-bottom:22px;
    padding:13px 15px;
    border-radius:8px;
    font-size:12px;
    line-height:1.45;
}

.driver-alert--success{
    border:1px solid #9fd4b8;
    background:#eaf8f1;
    color:#12623f;
}

.driver-alert--error{
    border:1px solid #efb8b4;
    background:#fff1f0;
    color:#a52b23;
}

.driver-alert ul{
    margin:8px 0 0 18px;
    padding:0;
}

/* =========================================================
   PESTAÑAS
   ========================================================= */

.driver-admin__tabs{
    display:flex;
    flex-wrap:wrap;
    gap:10px;
    margin-bottom:42px;
}

.driver-admin__tab{
    min-width:115px;
    height:43px;
    padding:0 26px;
    border:1px solid #cfc9bd;
    border-radius:7px;
    background:transparent;
    color:#536072;
    font:inherit;
    font-size:13px;
    font-weight:600;
    cursor:pointer;
    transition:.18s ease;
}

.driver-admin__tab:hover{
    border-color:#8f98a4;
    background:rgba(255,255,255,.35);
}

.driver-admin__tab.is-active{
    border-color:#565d67;
    background:#565d67;
    color:#fff;
}

.driver-tab-panel{
    display:none;
}

.driver-tab-panel.is-active{
    display:block;
}

/* =========================================================
   PREREGISTRO
   ========================================================= */

.driver-preregister{
    margin-bottom:44px;
    padding:0 0 24px;
    border:0;
    border-bottom:1px solid var(--driver-line);
    background:transparent;
    box-shadow:none;
}

.driver-preregister__header{
    display:flex;
    justify-content:space-between;
    align-items:flex-start;
    gap:25px;
}

.driver-preregister__eyebrow{
    display:block;
    margin-bottom:6px;
    color:#ef6c22;
    font-size:10px;
    font-weight:800;
    letter-spacing:.08em;
    text-transform:uppercase;
}

.driver-preregister h2{
    margin:0;
    color:#2f3947;
    font-size:20px;
    font-weight:600;
}

.driver-preregister p{
    max-width:640px;
    margin:5px 0 0;
    color:var(--driver-muted);
    font-size:12px;
    line-height:1.5;
}

.driver-progress-summary{
    min-width:135px;
    text-align:right;
}

.driver-progress-summary strong{
    display:block;
    color:#303946;
    font-size:28px;
    line-height:1;
}

.driver-progress-summary span{
    display:block;
    margin-top:5px;
    color:var(--driver-muted);
    font-size:10px;
}

.driver-progress{
    height:7px;
    margin:17px 0 18px;
    overflow:hidden;
    border-radius:999px;
    background:#e2ddd4;
}

.driver-progress__bar{
    height:100%;
    min-width:2px;
    border-radius:inherit;
    background:linear-gradient(90deg,#ef6c22,#f5a43c);
}

.driver-preregister__grid{
    display:grid;
    grid-template-columns:repeat(4,minmax(0,1fr));
    gap:9px;
}

.driver-preregister__grid article{
    position:relative;
    min-height:76px;
    padding:11px;
    border:1px solid #ddd8ce;
    border-radius:7px;
    background:rgba(255,253,248,.62);
}

.driver-preregister__grid article > span{
    display:block;
    margin-bottom:6px;
    color:#747a84;
    font-size:9px;
}

.driver-preregister__grid article > strong{
    display:block;
    padding-right:56px;
    color:#1f2c40;
    font-size:11px;
    line-height:1.35;
    overflow-wrap:anywhere;
}

.driver-preregister__grid article > small{
    position:absolute;
    top:9px;
    right:8px;
    padding:3px 6px;
    border-radius:999px;
    background:#edf4fb;
    color:#376b99;
    font-size:7px;
    font-weight:700;
    text-transform:uppercase;
}

.driver-pending-summary{
    margin-top:16px;
    padding-top:14px;
    border-top:1px solid #ded9cf;
}

.driver-pending-summary > strong{
    display:block;
    margin-bottom:9px;
    color:#303946;
    font-size:11px;
}

.driver-pending-summary > div{
    display:flex;
    flex-wrap:wrap;
    gap:6px;
}

.driver-pending-summary span{
    display:inline-flex;
    min-height:24px;
    align-items:center;
    padding:0 8px;
    border-radius:999px;
    background:#fff0d8;
    color:#91540d;
    font-size:9px;
    font-weight:600;
}

.driver-complete-summary{
    margin-top:16px;
    padding:11px;
    border-radius:7px;
    background:#e9f8ef;
    color:#17663f;
    font-size:11px;
    font-weight:600;
}

/* =========================================================
   ENCABEZADOS DE BLOQUE
   ========================================================= */

.driver-section-heading{
    margin:0 0 21px;
}

.driver-section-heading--spaced{
    margin-top:48px;
}

.driver-section-heading h2{
    margin:0;
    color:#253247;
    font-size:18px;
    font-weight:600;
    letter-spacing:-.2px;
}

.driver-section-heading p{
    margin:3px 0 0;
    color:var(--driver-muted);
    font-size:12px;
    font-weight:300;
}

/* =========================================================
   FORMULARIOS PLANOS COMO EL SOCIO
   ========================================================= */

.driver-form{
    margin:0 0 26px;
}

.driver-form-card{
    padding:0 0 26px;
    border:0;
    border-bottom:1px solid var(--driver-line);
    border-radius:0;
    background:transparent;
    box-shadow:none;
}

.driver-form-grid{
    display:grid;
    align-items:start;
    gap:24px;
    margin-bottom:19px;
}

.driver-form-grid--4{
    grid-template-columns:repeat(4,minmax(0,1fr));
}

.driver-form-grid--3{
    grid-template-columns:repeat(3,minmax(0,1fr));
}

.driver-form-grid--2{
    grid-template-columns:repeat(2,minmax(0,1fr));
}

.driver-form-grid > label,
.driver-form-grid > div{
    min-width:0;
}

.driver-form label{
    display:grid;
    align-content:start;
    gap:8px;
}

.driver-form label > span{
    color:var(--driver-text);
    font-size:13px;
    font-weight:500;
    line-height:1.25;
}

.driver-form label > span b{
    color:var(--driver-red);
}

.driver-form input,
.driver-form select,
.driver-form textarea{
    width:100%;
    height:42px;
    min-height:42px;
    margin:0;
    padding:0 12px;
    border:1px solid #d2d2d2;
    border-radius:7px;
    background:#fff;
    color:var(--driver-text);
    font:inherit;
    font-size:13px;
    outline:none;
    box-shadow:none;
}

.driver-form textarea{
    height:auto;
    min-height:90px;
    padding:10px 12px;
    resize:vertical;
}

.driver-form input:focus,
.driver-form select:focus,
.driver-form textarea:focus{
    border-color:var(--driver-blue);
    box-shadow:0 0 0 2px rgba(78,149,217,.12);
}

.driver-form input[readonly],
.driver-form input:disabled,
.driver-form select:disabled{
    background:#f1eee7;
    color:#666d77;
    cursor:not-allowed;
}

.driver-form select{
    appearance:auto;
    cursor:pointer;
}

.driver-field-wide{
    grid-column:span 2;
}

.driver-field-note{
    display:block;
    min-height:13px;
    margin-top:-4px;
    color:#7a7a7a;
    font-size:9px;
    font-weight:300;
    line-height:1.3;
}

.driver-field-note.is-valid{
    color:#168a55;
    font-weight:600;
}

.driver-form-checks{
    display:grid;
    align-content:end;
    gap:10px;
    min-height:70px;
    padding-top:21px;
}

.driver-check{
    display:flex!important;
    align-items:flex-start;
    gap:9px!important;
}

.driver-check input{
    width:17px;
    height:17px;
    min-height:17px;
    margin:1px 0 0;
    padding:0;
    flex:0 0 auto;
}

.driver-check span{
    font-size:12px!important;
    line-height:1.4;
}

.driver-form-actions{
    display:flex;
    justify-content:flex-end;
    align-items:center;
    min-height:42px;
    margin-top:15px;
}

.driver-btn{
    width:auto;
    min-width:145px;
    height:42px;
    min-height:42px;
    padding:0 20px;
    border:0;
    border-radius:7px;
    font:inherit;
    font-size:12px;
    font-weight:600;
    text-decoration:none;
    cursor:pointer;
    transition:.18s ease;
}

.driver-btn--primary{
    background:var(--driver-blue);
    color:#fff;
}

.driver-btn--primary:hover{
    background:var(--driver-blue-dark);
}

.driver-btn--secondary{
    border:1px solid var(--driver-line);
    background:#fff;
    color:var(--driver-text);
}

.driver-btn--secondary:hover{
    border-color:var(--driver-blue);
    color:var(--driver-blue-dark);
}

/* =========================================================
   VERIFICACIÓN DE TELÉFONO
   ========================================================= */

.driver-phone-verification{
    min-width:0;
}

.driver-phone-verification > label{
    width:100%;
}

.driver-phone-verification__control{
    position:relative;
    display:block;
    width:100%;
}

.driver-phone-verification__control input{
    width:100%;
    padding-right:125px;
}

.driver-btn--verify{
    position:absolute;
    top:50%;
    right:7px;
    transform:translateY(-50%);
    width:auto;
    min-width:105px;
    height:27px;
    min-height:27px;
    padding:0 11px;
    border:0;
    border-radius:999px;
    background:#ffd7f4;
    color:#777;
    font-size:9px;
    white-space:nowrap;
}

.driver-btn--verify:hover{
    background:#f3bfe5;
    color:#555;
}

.driver-btn--verify.is-verified{
    background:#dff5e9;
    color:#17663f;
}

.driver-phone-verification__status{
    display:block;
    min-height:13px;
    margin-top:2px;
    color:#99610d;
    font-size:9px;
    line-height:1.3;
}

.driver-phone-verification__status.is-verified{
    color:#17663f;
    font-weight:600;
}

/* =========================================================
   CONTACTOS DE EMERGENCIA
   ========================================================= */

.driver-emergency-card{
    margin-bottom:12px;
    border:1px solid var(--driver-line-dark);
    border-radius:8px;
    background:transparent;
    overflow:hidden;
}

.driver-emergency-card[open]{
    border-color:#8e8e8e;
}

.driver-emergency-card summary{
    min-height:54px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap:12px;
    padding:0 14px;
    cursor:pointer;
    list-style:none;
}

.driver-emergency-card summary::-webkit-details-marker{
    display:none;
}

.driver-emergency-card summary span{
    color:var(--driver-text);
    font-size:13px;
    font-weight:700;
}

.driver-emergency-card summary span b{
    margin-left:7px;
    padding:3px 7px;
    border-radius:999px;
    background:#edf4fb;
    color:#376b99;
    font-size:7px;
    text-transform:uppercase;
}

.driver-emergency-card summary small{
    padding:5px 10px;
    border-radius:999px;
    background:var(--driver-yellow-soft);
    color:#8a500c;
    font-size:9px;
    font-weight:700;
}

.driver-emergency-card__body{
    padding:15px;
    border-top:1px solid var(--driver-line);
}

.driver-emergency-consent{
    margin-top:5px;
    padding:11px;
    border:1px solid var(--driver-line);
    border-radius:7px;
    background:rgba(248,245,237,.66);
}

/* =========================================================
   REFERENCIAS PERSONALES
   ========================================================= */

.driver-reference-block{
    margin-bottom:12px;
    padding:15px;
    border:1px solid var(--driver-line-dark);
    border-radius:8px;
    background:transparent;
}

.driver-reference-block__header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap:12px;
    margin-bottom:15px;
}

.driver-reference-block__header h3{
    margin:0;
    color:var(--driver-text);
    font-size:13px;
}

.driver-reference-block__header span{
    display:inline-flex;
    align-items:center;
    min-height:23px;
    margin-top:5px;
    padding:0 9px;
    border-radius:999px;
    background:var(--driver-yellow-soft);
    color:#91540d;
    font-size:9px;
    font-weight:700;
}

.driver-reference-consent{
    margin-top:6px;
    padding:11px;
    border:1px solid var(--driver-line);
    border-radius:7px;
    background:rgba(248,245,237,.66);
}

.driver-security-note{
    display:grid;
    gap:4px;
    margin-top:17px;
    padding:12px 14px;
    border:1px solid #eabf7a;
    border-radius:8px;
    background:#fff7e8;
}

.driver-security-note strong{
    color:#85520e;
    font-size:11px;
}

.driver-security-note span{
    color:#755f3f;
    font-size:10px;
    line-height:1.45;
}

/* =========================================================
   DOCUMENTACIÓN - ACORDEONES TIPO SOCIO
   ========================================================= */

.driver-doc-list{
    display:grid;
    gap:11px;
}

.driver-doc-item{
    padding:0;
    border:1px solid var(--driver-line-dark);
    border-radius:8px;
    background:transparent;
    overflow:hidden;
}

.driver-doc-item:has(.driver-badge--approved){
    border-color:var(--driver-green);
}

.driver-doc-item:has(.driver-badge--pending){
    border-color:var(--driver-yellow);
}

.driver-doc-item__head{
    min-height:56px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap:14px;
    margin:0;
    padding:12px 14px;
}

.driver-doc-item__head > div{
    display:flex;
    align-items:center;
    gap:11px;
}

.driver-doc-item__head strong{
    color:#111827;
    font-size:13px;
}

.driver-doc-link{
    color:var(--driver-blue-dark);
    font-size:11px;
    font-weight:600;
    text-decoration:none;
}

.driver-badge{
    display:inline-flex;
    align-items:center;
    min-height:23px;
    padding:0 9px;
    border-radius:999px;
    font-size:9px;
    font-weight:700;
}

.driver-badge--approved{
    background:#dcfce7;
    color:#166534;
}

.driver-badge--pending{
    background:#fef3c7;
    color:#92400e;
}

.driver-badge--rejected{
    background:#fee2e2;
    color:#991b1b;
}

.driver-badge--missing{
    background:#ececec;
    color:#636363;
}

.driver-upload-form{
    display:grid;
    grid-template-columns:minmax(0,1fr) auto;
    align-items:center;
    gap:12px;
    padding:0 14px 14px;
}

.driver-upload-form input[type="file"]{
    min-width:0;
    height:auto;
    min-height:78px;
    padding:13px;
    border:1px dashed #aeb3ba;
    border-radius:7px;
    background:#fff;
    cursor:pointer;
}

.driver-upload-form input[type="file"]:hover{
    border-color:var(--driver-blue);
}

.driver-doc-note{
    margin:0 14px 13px;
    padding:9px 11px;
    border-radius:7px;
    background:#fef2f2;
    color:#991b1b;
    font-size:10px;
}

.driver-submit-box{
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap:20px;
    margin-top:24px;
    padding:15px;
    border:1px solid var(--driver-line);
    border-radius:8px;
    background:rgba(255,255,255,.30);
}

.driver-submit-box > div{
    display:grid;
    gap:4px;
}

.driver-submit-box strong{
    font-size:12px;
}

.driver-submit-box span{
    color:var(--driver-muted);
    font-size:10px;
}

/* =========================================================
   TARJETAS DE OTRAS PESTAÑAS
   ========================================================= */

.driver-kpis{
    display:grid;
    grid-template-columns:repeat(4,1fr);
    gap:10px;
    margin-bottom:16px;
}

.driver-kpis article,
.driver-card{
    border:1px solid var(--driver-line);
    background:rgba(255,255,255,.43);
    box-shadow:none;
}

.driver-kpis article{
    min-height:76px;
    padding:13px 14px;
    border-radius:8px;
}

.driver-kpis span,
.driver-data span{
    display:block;
    margin-bottom:7px;
    color:var(--driver-muted);
    font-size:10px;
}

.driver-kpis strong{
    font-size:19px;
}

.driver-card{
