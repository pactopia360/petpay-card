/* =========================================================
   MODAL VERIFICACIÓN
   ========================================================= */

.driver-modal-open{
    overflow:hidden;
}

.driver-verification-modal[hidden]{
    display:none;
}

.driver-verification-modal{
    position:fixed;
    inset:0;
    z-index:9999;
    display:grid;
    place-items:center;
    padding:18px;
}

.driver-verification-modal__backdrop{
    position:absolute;
    inset:0;
    background:rgba(10,18,30,.52);
    backdrop-filter:blur(3px);
}

.driver-verification-modal__dialog{
    position:relative;
    z-index:1;
    width:min(430px,100%);
    padding:24px;
    border:1px solid rgba(255,255,255,.55);
    border-radius:14px;
    background:var(--driver-surface);
    box-shadow:0 30px 80px rgba(0,0,0,.25);
}

.driver-verification-modal__close{
    position:absolute;
    top:10px;
    right:12px;
    width:32px;
    height:32px;
    padding:0;
    border:0;
    border-radius:50%;
    background:#eeeae2;
    color:#384252;
    font-size:21px;
    cursor:pointer;
}

.driver-verification-modal__eyebrow{
    display:block;
    margin-bottom:5px;
    color:#ef6c22;
    font-size:9px;
    font-weight:800;
    text-transform:uppercase;
}

.driver-verification-modal__dialog h2{
    margin:0;
    color:#293446;
    font-size:22px;
}

.driver-verification-modal__dialog p{
    margin:8px 0 17px;
    color:#707681;
    font-size:12px;
    line-height:1.5;
}

.driver-verification-modal__number{
    display:flex;
    justify-content:space-between;
    gap:14px;
    margin-bottom:17px;
    padding:10px 12px;
    border:1px solid #dcd6ca;
    border-radius:8px;
    background:#f5f1e8;
}

.driver-verification-modal__number span{
    color:#7b8089;
    font-size:10px;
}

.driver-verification-modal__number strong{
    font-size:11px;
}

.driver-verification-modal__code{
    display:grid;
    gap:8px;
}

.driver-verification-modal__code span{
    font-size:11px;
    font-weight:600;
}

.driver-verification-modal__code input{
    width:100%;
    height:48px;
    border:1px solid #cfd3d8;
    border-radius:8px;
    background:#fff;
    font-size:22px;
    font-weight:700;
    letter-spacing:.25em;
    text-align:center;
    outline:none;
}

.driver-verification-modal__feedback{
    margin-top:12px;
    padding:9px 11px;
    border-radius:7px;
    font-size:11px;
}

.driver-verification-modal__feedback[data-type="success"]{
    background:#e8f8ef;
    color:#17663f;
}

.driver-verification-modal__feedback[data-type="error"]{
    background:#fff0ef;
    color:#a52b23;
}

.driver-verification-modal__actions{
    display:flex;
    justify-content:flex-end;
    gap:9px;
    margin-top:17px;
}

.driver-verification-modal__local{
    display:block;
    margin-top:13px;
    color:#6f7480;
    font-size:9px;
    text-align:center;
}

