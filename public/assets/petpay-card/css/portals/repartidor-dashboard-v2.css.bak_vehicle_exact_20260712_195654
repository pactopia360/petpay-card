    position: absolute;
    top: 50%;
    right: 18px;
    transform: translateY(-50%);
    color: #071a36;
    font-size: 16px;
    transition: transform .18s ease;
}

.driver-section-heading--collapsible.is-open
.driver-section-chevron {
    transform: translateY(-50%) rotate(180deg);
}

.driver-section-collapsible-content.is-collapsed {
    display: none !important;
}

.driver-section-collapsible-content:not(.is-collapsed) {
    margin-top: 12px;
}

.driver-document-workspace[hidden] {
    display: none !important;
}

/* ===== PETPAY: MÓDULO DE VEHÍCULOS V2 ===== */

.driver-vehicles {
    width: 100%;
    color: #071a36;
}

.driver-vehicles__intro {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    margin: 4px 0 18px;
}

.driver-vehicles__title h2 {
    margin: 0 0 4px;
    color: #071a36;
    font-size: clamp(22px, 2vw, 30px);
    font-weight: 800;
    line-height: 1.15;
}

.driver-vehicles__title p {
    margin: 0;
    color: #647084;
    font-size: 13px;
}

.driver-vehicle-btn {
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    padding: 10px 20px;
    border: 1px solid transparent;
    border-radius: 9px;
    font: inherit;
    font-size: 13px;
    font-weight: 800;
    line-height: 1;
    text-decoration: none;
    cursor: pointer;
    transition:
        transform .16s ease,
        box-shadow .16s ease,
        background-color .16s ease,
        border-color .16s ease;
}

.driver-vehicle-btn:hover {
    transform: translateY(-1px);
}

.driver-vehicle-btn--dark {
    border-color: #142239;
    background: #142239;
    color: #fff;
    box-shadow: 0 8px 18px rgba(7, 26, 54, .12);
}

.driver-vehicle-btn--dark:hover {
    background: #071a36;
    border-color: #071a36;
}

.driver-vehicle-btn--outline {
    border-color: #9dafc5;
    background: transparent;
    color: #071a36;
}

.driver-vehicle-btn--outline:hover {
    border-color: #4c98df;
    background: rgba(76, 152, 223, .06);
}

.driver-vehicles__list {
    display: grid;
    gap: 14px;
}

.driver-vehicle-module {
    width: 100%;
    overflow: hidden;
    border: 1px solid #9dafc5;
    border-radius: 9px;
    background: rgba(255, 255, 255, .08);
}

.driver-vehicle-module[open] {
    background: rgba(255, 255, 255, .16);
    box-shadow: 0 10px 24px rgba(7, 26, 54, .05);
}

.driver-vehicle-module--new {
    margin-bottom: 18px;
}

.driver-vehicle-module--new[hidden] {
    display: none !important;
}

.driver-vehicle-module__header {
    min-height: 72px;
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 18px;
    color: #071a36;
    list-style: none;
    cursor: pointer;
    user-select: none;
}

summary.driver-vehicle-module__header::-webkit-details-marker {
    display: none;
}

.driver-vehicle-module__header::marker {
    display: none;
    content: "";
}

.driver-vehicle-module__icon {
    width: 26px;
    height: 26px;
    flex: 0 0 26px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 2px solid #55657a;
    border-radius: 50%;
    color: #55657a;
    font-size: 15px;
    font-weight: 900;
}

.driver-vehicle-module__header > div:not(.driver-vehicle-module__actions) {
    min-width: 0;
    flex: 1;
}

.driver-vehicle-module__header strong {
    display: block;
    overflow: hidden;
    margin-bottom: 3px;
    color: #071a36;
    font-size: 15px;
    font-weight: 800;
    line-height: 1.25;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.driver-vehicle-module__header small {
    display: block;
    color: #647084;
    font-size: 12px;
    line-height: 1.35;
}

.driver-vehicle-module__actions {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 8px;
}

.driver-vehicle-status {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 6px 10px;
    border-radius: 999px;
    background: #fff0c8;
    color: #8a6500;
    font-size: 10px;
    font-weight: 800;
    white-space: nowrap;
}

.driver-vehicle-status.is-active,
.driver-vehicle-status.is-approved {
    background: #def5e8;
    color: #087344;
}

.driver-vehicle-status.is-rejected,
.driver-vehicle-status.is-inactive {
    background: #ffe0e0;
    color: #a21a1a;
}

.driver-vehicle-icon-btn {
    width: 40px;
    height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    border: 1px solid #9dafc5;
    border-radius: 9px;
    background: rgba(255, 255, 255, .45);
    color: #071a36;
    cursor: pointer;
    transition:
        border-color .16s ease,
        background-color .16s ease;
}

.driver-vehicle-icon-btn:hover {
    border-color: #4c98df;
    background: #fff;
}

.driver-vehicle-chevron {
    display: inline-flex;
    margin-left: 4px;
    color: #071a36;
    font-size: 20px;
    line-height: 1;
    transition: transform .18s ease;
}

.driver-vehicle-module[open]
.driver-vehicle-chevron {
    transform: rotate(180deg);
}

.driver-vehicle-form {
    padding: 16px;
    border-top: 1px solid #9dafc5;
}

.driver-vehicle-section {
    overflow: hidden;
    margin-bottom: 14px;
    border: 1px solid #9dafc5;
    border-radius: 9px;
    background: transparent;
}

.driver-vehicle-section:last-of-type {
    margin-bottom: 0;
}

.driver-vehicle-section > summary {
    min-height: 58px;
    display: flex;
    align-items: center;
    padding: 14px 46px 14px 16px;
    position: relative;
    color: #071a36;
    font-size: 14px;
    font-weight: 800;
    list-style: none;
    cursor: pointer;
}

.driver-vehicle-section > summary::-webkit-details-marker {
    display: none;
}

.driver-vehicle-section > summary::marker {
    display: none;
    content: "";
}

.driver-vehicle-section > summary::after {
    content: "⌄";
    position: absolute;
    top: 50%;
    right: 18px;
    transform: translateY(-50%);
    color: #071a36;
    font-size: 18px;
    transition: transform .18s ease;
}

.driver-vehicle-section[open] > summary::after {
    transform: translateY(-50%) rotate(180deg);
}

.driver-vehicle-section[open] > summary {
    border-bottom: 1px solid #9dafc5;
}

.driver-vehicle-section__body {
    padding: 18px 16px;
}

.driver-vehicle-grid {
    display: grid;
    gap: 14px;
}

.driver-vehicle-grid--2 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
}

.driver-vehicle-grid--color {
    grid-template-columns: minmax(0, 1fr) 140px;
}

.driver-vehicle-form label {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 7px;
    color: #071a36;
    font-size: 12px;
    font-weight: 700;
}

.driver-vehicle-form input,
.driver-vehicle-form select,
.driver-vehicle-form textarea {
    width: 100%;
    min-height: 42px;
    padding: 10px 12px;
    border: 1px solid #9dafc5;
    border-radius: 8px;
    outline: none;
    background: rgba(255, 255, 255, .84);
    color: #071a36;
    font: inherit;
    font-size: 13px;
    box-sizing: border-box;
    transition:
        border-color .16s ease,
        box-shadow .16s ease,
        background-color .16s ease;
}

.driver-vehicle-form textarea {
    min-height: 92px;
    resize: vertical;
}

.driver-vehicle-form input:focus,
.driver-vehicle-form select:focus,
.driver-vehicle-form textarea:focus {
    border-color: #4c98df;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(76, 152, 223, .13);
}

.driver-vehicle-form input[readonly],
.driver-vehicle-form input:disabled,
.driver-vehicle-form select:disabled,
.driver-vehicle-form textarea:disabled {
    background: rgba(230, 232, 234, .55);
    color: #657083;
    cursor: not-allowed;
}

.driver-vehicle-form input[type="file"] {
    padding: 7px;
}

.driver-vehicle-form input[type="checkbox"] {
    width: 18px;
    min-height: 18px;
    padding: 0;
}

.driver-vehicle-form__actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 16px;
}

.driver-vehicles__empty {
    padding: 28px 20px;
    border: 1px dashed #9dafc5;
    border-radius: 9px;
    color: #647084;
    text-align: center;
    font-size: 13px;
}

/* Mantiene cerrados los bloques hasta que el repartidor los abra */
.driver-vehicle-module:not([open]) > .driver-vehicle-form,
.driver-vehicle-section:not([open]) > .driver-vehicle-section__body {
    display: none;
}

@media (max-width: 760px) {
    .driver-vehicles__intro {
        align-items: stretch;
        flex-direction: column;
    }

    .driver-vehicles__intro .driver-vehicle-btn {
        width: 100%;
    }

    .driver-vehicle-module__header {
        min-height: 66px;
        padding: 12px;
        gap: 10px;
    }

    .driver-vehicle-module__header strong {
        white-space: normal;
    }

    .driver-vehicle-status {
        display: none;
    }

    .driver-vehicle-form {
        padding: 12px;
    }

    .driver-vehicle-grid--2,
    .driver-vehicle-grid--color {
        grid-template-columns: 1fr;
    }

    .driver-vehicle-section__body {
        padding: 14px 12px;
    }

    .driver-vehicle-form__actions {
        align-items: stretch;
        flex-direction: column-reverse;
    }

    .driver-vehicle-form__actions .driver-vehicle-btn {
        width: 100%;
    }
}

@media (max-width: 440px) {
    .driver-vehicle-module__actions {
        gap: 5px;
    }

    .driver-vehicle-icon-btn {
        width: 36px;
        height: 36px;
    }

    .driver-vehicle-chevron {
        margin-left: 0;
    }
}

/* ===== FIN PETPAY: MÓDULO DE VEHÍCULOS V2 ===== */
