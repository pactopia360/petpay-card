/* PETPAY COMERCIO BRANDING - REFERENCIA FINAL */

.commerce-branding-home {
    display: grid;
    gap: 22px;
}

.commerce-branding-home__intro {
    display: grid;
    gap: 4px;
    margin-bottom: 8px;
}

.commerce-branding-home__intro h2 {
    margin: 0;
    color: #374151;
    font-size: 20px;
    font-weight: 850;
}

.commerce-branding-home__intro h3 {
    margin: 0;
    color: #475569;
    font-size: 16px;
    font-weight: 500;
}

.commerce-branding-home__intro p {
    max-width: 980px;
    margin: 8px 0 0;
    color: #475569;
    font-size: 14px;
    line-height: 1.45;
}

.commerce-branding-assets {
    display: grid;
    gap: 28px;
}

.commerce-branding-asset {
    display: grid;
    grid-template-columns: minmax(250px, 340px) minmax(0, 1fr) 48px;
    gap: 28px;
    align-items: center;
}

.commerce-branding-asset__copy h3 {
    margin: 0;
    color: #4b5563;
    font-size: clamp(25px, 2.5vw, 34px);
    line-height: .98;
    letter-spacing: -.04em;
}

.commerce-branding-asset__copy h4 {
    margin: 4px 0 0;
    color: #475569;
    font-size: 16px;
    font-weight: 500;
}

.commerce-branding-asset__copy p {
    max-width: 290px;
    margin: 22px 0 0;
    color: #475569;
    font-size: 17px;
    line-height: 1.12;
}

.commerce-branding-upload {
    position: relative;
    display: grid;
    place-items: center;
    min-height: 146px;
    overflow: hidden;
    border: 1.5px dashed #b8c0cc;
    border-radius: 14px;
    background: rgba(255, 255, 255, .62);
    cursor: pointer;
    transition: border-color .18s ease, box-shadow .18s ease, transform .18s ease;
}

.commerce-branding-upload--header {
    min-height: 146px;
    max-width: 600px;
}

.commerce-branding-upload--square {
    width: 146px;
    min-height: 146px;
}

.commerce-branding-upload--listing {
    width: 292px;
    min-height: 146px;
}

.commerce-branding-upload:hover,
.commerce-branding-upload:focus-within {
    border-color: #6b7280;
    box-shadow: 0 14px 32px rgba(15, 23, 42, .08);
    transform: translateY(-1px);
}

.commerce-branding-upload input[type="file"] {
    position: absolute;
    inset: 0;
    z-index: 5;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: pointer;
}

.commerce-branding-upload__placeholder {
    position: relative;
    z-index: 2;
    display: grid;
    place-items: center;
    gap: 4px;
    padding: 16px;
    text-align: center;
    color: #6b7280;
    pointer-events: none;
}

.commerce-branding-upload__placeholder svg {
    width: 22px;
    height: 22px;
    stroke: currentColor;
}

.commerce-branding-upload__placeholder strong {
    font-size: 13px;
    font-weight: 500;
}

.commerce-branding-upload__placeholder span {
    font-size: 12px;
    line-height: 1.2;
}

.commerce-branding-upload__preview {
    position: absolute;
    inset: 0;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.commerce-branding-upload__preview[hidden] {
    display: none !important;
}

.commerce-branding-upload.has-image .commerce-branding-upload__placeholder {
    opacity: 0;
}

.commerce-branding-asset__tools {
    display: grid;
    gap: 12px;
    justify-items: center;
}

.commerce-branding-tool {
    width: 30px;
    height: 30px;
    display: inline-grid;
    place-items: center;
    padding: 0;
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: #a3a9b1;
    cursor: pointer;
}

.commerce-branding-tool:hover {
    color: #4b5563;
}

.commerce-branding-tool svg {
    width: 24px;
    height: 24px;
    stroke: currentColor;
}

.commerce-branding-tool[disabled] {
    opacity: .45;
    cursor: not-allowed;
}

.commerce-branding-status {
    grid-column: 2 / 3;
    display: flex;
    align-items: center;
    gap: 9px;
    width: fit-content;
    margin-top: -14px;
    padding: 7px 10px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 900;
}

.commerce-branding-status--pending {
    background: rgba(245, 158, 11, .12);
    color: #b45309;
}

.commerce-branding-status--approved {
    background: rgba(16, 185, 129, .12);
    color: #047857;
}

.commerce-branding-status--rejected {
    background: rgba(239, 68, 68, .12);
    color: #b91c1c;
}

.commerce-branding-status__dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: currentColor;
}

.commerce-branding-rejection {
    grid-column: 2 / 3;
    margin-top: -16px;
    padding: 10px 12px;
    border-radius: 12px;
    background: rgba(239, 68, 68, .08);
    color: #991b1b;
    font-size: 12px;
    line-height: 1.4;
}

.commerce-branding-actions {
    display: flex;
    justify-content: flex-end;
    margin-top: 6px;
}

.commerce-branding-save {
    min-width: 164px;
    min-height: 40px;
    padding: 0 22px;
    border: 0;
    border-radius: 999px;
    background: #a7a49e;
    color: #fff;
    font-weight: 850;
    cursor: not-allowed;
    opacity: .72;
}

.commerce-branding-save.is-ready {
    background: #4b5563;
    cursor: pointer;
    opacity: 1;
}

.commerce-branding-modal[hidden] {
    display: none !important;
}

.commerce-branding-modal {
    position: fixed;
    inset: 0;
    z-index: 2000;
    display: grid;
    place-items: center;
    padding: 20px;
    background: rgba(15, 23, 42, .55);
    backdrop-filter: blur(6px);
}

.commerce-branding-modal__card {
    width: min(520px, 100%);
    padding: 20px;
    border-radius: 22px;
    background: #fff;
    box-shadow: 0 24px 70px rgba(15, 23, 42, .24);
}

.commerce-branding-modal__card h3 {
    margin: 0;
    color: #111827;
}

.commerce-branding-modal__card p {
    margin: 10px 0 0;
    color: #475569;
    line-height: 1.5;
}

.commerce-branding-modal__close {
    margin-top: 16px;
    min-height: 38px;
    padding: 0 16px;
    border: 0;
    border-radius: 999px;
    background: #111827;
    color: #fff;
    font-weight: 900;
    cursor: pointer;
}

.commerce-admin__tab[data-commerce-tab-button="branding"].is-active {
    background: #4b5563 !important;
    border-color: #4b5563 !important;
    color: #fff !important;
    opacity: 1 !important;
}

@media (max-width: 900px) {
    .commerce-branding-asset {
        grid-template-columns: 1fr;
        gap: 14px;
    }

    .commerce-branding-status,
    .commerce-branding-rejection {
        grid-column: 1;
        margin-top: 0;
    }

    .commerce-branding-asset__tools {
        grid-auto-flow: column;
        justify-content: flex-start;
        justify-items: start;
    }

    .commerce-branding-upload--header,
    .commerce-branding-upload--listing {
        width: 100%;
        max-width: none;
    }
}

@media (max-width: 560px) {
    .commerce-branding-upload--square,
    .commerce-branding-upload--listing {
        width: 100%;
    }

    .commerce-branding-actions {
        justify-content: stretch;
    }

    .commerce-branding-save {
        width: 100%;
    }
}
