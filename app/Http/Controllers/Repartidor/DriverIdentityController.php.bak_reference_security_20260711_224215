<?php

namespace App\Http\Controllers\Repartidor;

use App\Http\Controllers\Controller;
use App\Models\Repartidor\DriverAddress;
use App\Models\Repartidor\DriverEmergencyContact;
use App\Models\Repartidor\DriverIdentityDocument;
use App\Models\Repartidor\DriverIdentityEvent;
use App\Models\Repartidor\DriverIdentityProfile;
use App\Models\Repartidor\DriverPersonalReference;
use App\Models\Repartidor\DriverUser;
use Illuminate\Http\JsonResponse;
use Illuminate\Http\RedirectResponse;
