    public function saveProfile(Request $request): RedirectResponse
    {
        $driver = $this->driver($request);
        $profile = $this->profile($driver);

        abort_if(
            $profile->isLocked(),
            422,
            'El expediente aprobado está bloqueado y no puede modificarse.'
        );

        $validated = $request->validate([
            'first_name' => ['required', 'string', 'max:120'],
            'paternal_last_name' => ['required', 'string', 'max:120'],
            'maternal_last_name' => ['nullable', 'string', 'max:120'],
            'curp' => [
                'required',
                'string',
                'size:18',
                'regex:/^[A-Z]{4}[0-9]{6}[HM][A-Z]{5}[A-Z0-9][0-9]$/',
            ],
            'home_phone' => ['nullable', 'string', 'max:30'],
            'mobile_phone' => ['required', 'string', 'max:30'],
            'contact_email' => ['required', 'email', 'max:190'],
            'data_processing_consent' => ['accepted'],
            'truth_declaration' => ['accepted'],
        ], [
            'curp.size' => 'La CURP debe tener exactamente 18 caracteres.',
            'curp.regex' => 'La CURP no tiene un formato válido.',
            'data_processing_consent.accepted' => 'Debes aceptar el tratamiento de datos.',
            'truth_declaration.accepted' => 'Debes confirmar que la información es verdadera.',
        ]);

        DB::connection('mysql_repartidor')->transaction(function () use (
            $driver,
            $profile,
            $validated,
            $request
        ): void {
            $firstName = $this->normalizeName($validated['first_name']);
            $paternalLastName = $this->normalizeName($validated['paternal_last_name']);
            $maternalLastName = $this->normalizeName(
                $validated['maternal_last_name'] ?? ''
            );

            $lastName = trim(
                $paternalLastName.' '.$maternalLastName
            );

            $driver->forceFill([
                'first_name' => $firstName,
                'last_name' => $lastName,
                'name' => trim($firstName.' '.$lastName),
                'phone' => trim($validated['mobile_phone']),
            ])->save();

            $profile->fill([
                'paternal_last_name' => $paternalLastName,
                'maternal_last_name' => $maternalLastName ?: null,
                'curp' => strtoupper(trim($validated['curp'])),
                'home_phone' => trim((string) ($validated['home_phone'] ?? '')) ?: null,
                'mobile_phone' => trim($validated['mobile_phone']),
                'contact_email' => strtolower(trim($validated['contact_email'])),
                'data_processing_consent' => true,
                'truth_declaration' => true,
                'status' => in_array(
                    $profile->status,
                    ['corrections_required', 'rejected'],
                    true
                ) ? 'draft' : $profile->status,
                'review_notes' => null,
                'approved_at' => null,
                'approved_by' => null,
                'rejected_at' => null,
                'rejected_by' => null,
                'identity_locked_at' => null,
                'identity_hash' => null,
            ])->save();

            $this->event(
                $profile,
                $request,
                'profile_saved',
                'Datos personales del repartidor actualizados.'
            );
        });

        return back()
            ->with('status', 'Datos personales guardados correctamente.')
            ->with('active_tab', 'usuario');
    }

    public function saveAddress(Request $request): RedirectResponse
    {
        $driver = $this->driver($request);
        $profile = $this->profile($driver);

        abort_if(
            $profile->isLocked(),
            422,
            'El expediente aprobado está bloqueado.'
        );

        $validated = $request->validate([
            'country' => ['required', 'string', 'max:100'],
            'postal_code' => ['required', 'string', 'max:10'],
            'state' => ['required', 'string', 'max:120'],
            'municipality' => ['required', 'string', 'max:150'],
            'city' => ['required', 'string', 'max:150'],
            'neighborhood' => ['required', 'string', 'max:180'],
            'street' => ['required', 'string', 'max:190'],
            'exterior_number' => ['required', 'string', 'max:40'],
            'interior_number' => ['nullable', 'string', 'max:40'],
            'references' => ['nullable', 'string', 'max:500'],
            'latitude' => ['nullable', 'numeric', 'between:-90,90'],
            'longitude' => ['nullable', 'numeric', 'between:-180,180'],
        ]);

        DB::connection('mysql_repartidor')->transaction(function () use (
            $driver,
            $profile,
            $validated,
            $request
        ): void {
            DriverAddress::query()
                ->where('driver_user_id', $driver->id)
                ->where('is_primary', true)
                ->update([
                    'is_primary' => false,
                ]);

            $address = DriverAddress::query()->create([
                'driver_user_id' => $driver->id,
                'country' => $this->normalizeName($validated['country']),
                'postal_code' => strtoupper(trim($validated['postal_code'])),
                'state' => $this->normalizeName($validated['state']),
                'municipality' => $this->normalizeName($validated['municipality']),
                'city' => $this->normalizeName($validated['city']),
                'neighborhood' => $this->normalizeName($validated['neighborhood']),
                'street' => $this->normalizeName($validated['street']),
                'exterior_number' => trim($validated['exterior_number']),
                'interior_number' => trim(
                    (string) ($validated['interior_number'] ?? '')
                ) ?: null,
                'references' => trim(
                    (string) ($validated['references'] ?? '')
                ) ?: null,
                'latitude' => $validated['latitude'] ?? null,
                'longitude' => $validated['longitude'] ?? null,
                'is_primary' => true,
                'is_active' => true,
            ]);

            $driver->forceFill([
                'state' => $address->state,
                'city' => $address->city,
            ])->save();

            $this->event(
                $profile,
                $request,
                'address_saved',
                'Dirección principal actualizada.',
                [
                    'address_id' => $address->id,
                    'postal_code' => $address->postal_code,
                ]
            );
        });

        return back()
            ->with('status', 'Dirección guardada correctamente.')
            ->with('active_tab', 'usuario');
    }

    public function saveEmergencyContact(Request $request): RedirectResponse
    {
        $driver = $this->driver($request);
        $profile = $this->profile($driver);

        abort_if(
            $profile->isLocked(),
            422,
            'El expediente aprobado está bloqueado.'
        );

        $allowedRelationships = [
            'mother',
            'father',
            'stepmother',
            'stepfather',
            'sister',
            'brother',
            'spouse',
            'partner',
            'daughter',
            'son',
            'grandmother',
            'grandfather',
            'aunt',
            'uncle',
            'cousin_female',
            'cousin_male',
            'friend_female',
            'friend_male',
            'coworker_female',
            'coworker_male',
            'other',
        ];

        $validated = $request->validate([
            'emergency_full_name' => ['required', 'string', 'max:190'],
            'emergency_relationship_code' => [
                'required',
                Rule::in($allowedRelationships),
            ],
            'emergency_phone' => ['required', 'string', 'max:30'],
            'emergency_alternate_phone' => ['nullable', 'string', 'max:30'],
            'emergency_email' => ['nullable', 'email', 'max:190'],
            'emergency_preferred_contact_time' => [
                'required',
                Rule::in(['morning', 'afternoon', 'evening', 'any']),
            ],
            'emergency_contact_consent' => ['accepted'],
        ], [
            'emergency_relationship_code.required' => 'Selecciona el parentesco del contacto.',
            'emergency_contact_consent.accepted' => 'Debes confirmar que el contacto autorizó ser registrado.',
        ]);

        $phone = $this->normalizeMexicanPhone(
            $validated['emergency_phone']
        );

        $alternatePhone = filled(
            $validated['emergency_alternate_phone'] ?? null
        )
            ? $this->normalizeMexicanPhone(
                $validated['emergency_alternate_phone']
            )
            : null;

        $driverPhone = $this->normalizeMexicanPhone(
            (string) $driver->phone
        );

        if ($phone === $driverPhone) {
            return back()
                ->withInput()
                ->withErrors([
                    'emergency_phone' => 'El contacto de emergencia no puede usar el mismo teléfono del repartidor.',
                ]);
        }

        if ($alternatePhone !== null && $alternatePhone === $phone) {
            return back()
                ->withInput()
                ->withErrors([
                    'emergency_alternate_phone' => 'El teléfono alterno debe ser distinto al principal.',
                ]);
        }

        $relationshipLabel = $this->relationshipLabel(
            $validated['emergency_relationship_code']
        );

        $existing = DriverEmergencyContact::query()
            ->where('driver_user_id', $driver->id)
            ->first();

        $phoneChanged = $existing === null
            || $existing->phone_normalized !== $phone;

        DB::connection('mysql_repartidor')->transaction(function () use (
            $driver,
            $profile,
            $validated,
            $request,
            $phone,
            $alternatePhone,
            $relationshipLabel,
            $phoneChanged
        ): void {
            DB::connection('mysql_repartidor')
                ->table('driver_emergency_contacts')
                ->updateOrInsert(
                    [
                        'driver_user_id' => $driver->id,
                    ],
                    [
                        'full_name' => $this->normalizeName(
                            $validated['emergency_full_name']
                        ),
                        'relationship' => $relationshipLabel,
                        'relationship_code' => $validated['emergency_relationship_code'],
                        'phone' => $phone,
                        'phone_normalized' => $phone,
                        'phone_hash' => hash('sha256', $phone),
                        'alternate_phone' => $alternatePhone,
                        'alternate_phone_normalized' => $alternatePhone,
                        'email' => strtolower(trim(
                            (string) ($validated['emergency_email'] ?? '')
                        )) ?: null,
                        'contact_consent' => true,
                        'preferred_contact_time' => $validated['emergency_preferred_contact_time'],
                        'is_verified' => $phoneChanged ? false : DB::raw('is_verified'),
                        'verified_at' => $phoneChanged ? null : DB::raw('verified_at'),
                        'verification_status' => $phoneChanged
                            ? 'pending'
                            : DB::raw('verification_status'),
                        'verification_attempts' => $phoneChanged
                            ? 0
                            : DB::raw('verification_attempts'),
                        'risk_status' => 'normal',
                        'created_at' => now(),
                        'updated_at' => now(),
                    ]
                );

            $this->event(
                $profile,
                $request,
                'emergency_contact_saved',
                'Contacto de emergencia actualizado con controles de seguridad.',
                [
                    'phone_changed' => $phoneChanged,
                    'relationship_code' => $validated['emergency_relationship_code'],
                    'phone_masked' => $this->maskPhone($phone),
                ]
            );
        });

        return back()
            ->with('status', 'Contacto de emergencia guardado correctamente.')
            ->with('active_tab', 'usuario');
    }
    public function saveReferences(Request $request): RedirectResponse
    {
        $driver = $this->driver($request);
        $profile = $this->profile($driver);

        abort_if(
            $profile->isLocked(),
            422,
            'El expediente aprobado está bloqueado.'
        );

        $allowedRelationships = [
            'mother',
            'father',
            'stepmother',
            'stepfather',
            'sister',
            'brother',
            'spouse',
            'partner',
            'daughter',
            'son',
            'grandmother',
            'grandfather',
            'aunt',
            'uncle',
            'cousin_female',
            'cousin_male',
            'friend_female',
            'friend_male',
            'neighbor_female',
            'neighbor_male',
            'coworker_female',
            'coworker_male',
            'boss_female',
            'boss_male',
            'client_female',
            'client_male',
            'other',
        ];

        $validated = $request->validate([
            'references' => ['required', 'array', 'size:2'],
            'references.*.full_name' => ['required', 'string', 'max:190'],
            'references.*.reference_type' => [
                'required',
                Rule::in(['family', 'non_family']),
            ],
            'references.*.relationship_code' => [
                'required',
                Rule::in($allowedRelationships),
            ],
            'references.*.years_known' => [
                'required',
                'integer',
                'min:1',
                'max:80',
            ],
            'references.*.lives_same_address' => [
                'required',
                'boolean',
            ],
            'references.*.preferred_contact_time' => [
                'required',
                Rule::in(['morning', 'afternoon', 'evening', 'any']),
            ],
            'references.*.contact_consent' => ['accepted'],
            'references.*.phone' => ['required', 'string', 'max:30'],
            'references.*.alternate_phone' => ['nullable', 'string', 'max:30'],
            'references.*.email' => ['nullable', 'email', 'max:190'],
        ], [
            'references.*.contact_consent.accepted' => 'Cada referencia debe autorizar ser contactada.',
            'references.*.years_known.min' => 'Debes conocer a cada referencia desde hace al menos un año.',
        ]);

        $references = array_values($validated['references']);

        foreach ($references as $index => &$reference) {
            $reference['full_name_normalized'] = $this->normalizeComparableName(
                $reference['full_name']
            );

            $reference['phone_normalized'] = $this->normalizeMexicanPhone(
                $reference['phone']
            );

            $reference['alternate_phone_normalized'] = filled(
                $reference['alternate_phone'] ?? null
            )
                ? $this->normalizeMexicanPhone(
                    $reference['alternate_phone']
                )
                : null;

            $expectedType = $this->relationshipType(
                $reference['relationship_code']
            );

            if (
                $reference['relationship_code'] !== 'other'
                && $expectedType !== $reference['reference_type']
            ) {
                return back()
                    ->withInput()
                    ->withErrors([
                        "references.$index.reference_type" =>
                            'El tipo de referencia no coincide con la relación seleccionada.',
                    ]);
            }

            if (
                $reference['alternate_phone_normalized'] !== null
                && $reference['alternate_phone_normalized'] === $reference['phone_normalized']
            ) {
                return back()
                    ->withInput()
                    ->withErrors([
                        "references.$index.alternate_phone" =>
                            'El teléfono alterno debe ser distinto al principal.',
                    ]);
            }
        }
        unset($reference);

        $driverPhone = $this->normalizeMexicanPhone(
            (string) $driver->phone
        );

        $emergencyPhone = DriverEmergencyContact::query()
            ->where('driver_user_id', $driver->id)
            ->value('phone_normalized');

        if (
            $references[0]['full_name_normalized']
            === $references[1]['full_name_normalized']
        ) {
            return back()
                ->withInput()
                ->withErrors([
                    'references.1.full_name' => 'Las dos referencias no pueden ser la misma persona.',
                ]);
        }

        if (
            $references[0]['phone_normalized']
            === $references[1]['phone_normalized']
        ) {
            return back()
                ->withInput()
                ->withErrors([
                    'references.1.phone' => 'Las dos referencias no pueden usar el mismo teléfono.',
                ]);
        }

        foreach ($references as $index => $reference) {
            if ($reference['phone_normalized'] === $driverPhone) {
                return back()
                    ->withInput()
                    ->withErrors([
                        "references.$index.phone" =>
                            'Una referencia no puede usar el teléfono del repartidor.',
                    ]);
            }

            if (
                filled($emergencyPhone)
                && $reference['phone_normalized'] === $emergencyPhone
            ) {
                return back()
                    ->withInput()
                    ->withErrors([
                        "references.$index.phone" =>
                            'Una referencia no puede usar el mismo teléfono del contacto de emergencia.',
                    ]);
            }
        }

        $exclusiveRelationships = [
            'mother',
            'father',
            'spouse',
            'partner',
        ];

        foreach ($exclusiveRelationships as $exclusiveRelationship) {
            $count = collect($references)
                ->where('relationship_code', $exclusiveRelationship)
                ->count();

            if ($count > 1) {
                return back()
                    ->withInput()
                    ->withErrors([
                        'references' =>
                            'No puedes registrar dos referencias con la relación '.
                            $this->relationshipLabel($exclusiveRelationship).'.',
                    ]);
            }
        }

        if (
            collect($references)
                ->where('lives_same_address', true)
                ->count() === 2
        ) {
            return back()
                ->withInput()
                ->withErrors([
                    'references' =>
                        'Al menos una referencia debe vivir en un domicilio distinto al del repartidor.',
                ]);
        }

        DB::connection('mysql_repartidor')->transaction(function () use (
            $driver,
            $profile,
            $references,
            $request
        ): void {
            foreach ($references as $index => $reference) {
                $position = $index + 1;

                $existing = DriverPersonalReference::query()
                    ->where('driver_user_id', $driver->id)
                    ->where('position', $position)
                    ->first();

                $phoneChanged = $existing === null
                    || $existing->phone_normalized !== $reference['phone_normalized'];

                DB::connection('mysql_repartidor')
                    ->table('driver_personal_references')
                    ->updateOrInsert(
                        [
                            'driver_user_id' => $driver->id,
                            'position' => $position,
                        ],
                        [
                            'reference_type' => $reference['reference_type'],
                            'full_name' => $this->normalizeName(
                                $reference['full_name']
                            ),
                            'relationship' => $this->relationshipLabel(
                                $reference['relationship_code']
                            ),
                            'relationship_code' => $reference['relationship_code'],
                            'years_known' => (int) $reference['years_known'],
                            'lives_same_address' => (bool) $reference['lives_same_address'],
                            'contact_consent' => true,
                            'preferred_contact_time' => $reference['preferred_contact_time'],
                            'phone' => $reference['phone_normalized'],
                            'phone_normalized' => $reference['phone_normalized'],
                            'phone_hash' => hash(
                                'sha256',
                                $reference['phone_normalized']
                            ),
                            'alternate_phone' => $reference['alternate_phone_normalized'],
                            'alternate_phone_normalized' => $reference['alternate_phone_normalized'],
                            'email' => strtolower(trim(
                                (string) ($reference['email'] ?? '')
                            )) ?: null,
                            'is_verified' => $phoneChanged
                                ? false
                                : DB::raw('is_verified'),
                            'verified_at' => $phoneChanged
                                ? null
                                : DB::raw('verified_at'),
                            'verification_status' => $phoneChanged
                                ? 'pending'
                                : DB::raw('verification_status'),
                            'verification_attempts' => $phoneChanged
                                ? 0
                                : DB::raw('verification_attempts'),
                            'risk_status' => 'normal',
                            'created_at' => now(),
                            'updated_at' => now(),
                        ]
                    );
            }

            $this->event(
                $profile,
                $request,
                'references_saved',
                'Referencias personales actualizadas con validaciones de seguridad.',
                [
                    'reference_count' => 2,
                    'relationships' => collect($references)
                        ->pluck('relationship_code')
                        ->values()
                        ->all(),
                ]
            );
        });

        return back()
            ->with('status', 'Referencias personales guardadas correctamente.')
            ->with('active_tab', 'usuario');
    }
    public function uploadDocument(Request $request): RedirectResponse
    {
        $driver = $this->driver($request);
        $profile = $this->profile($driver);

        abort_if(
            $profile->isLocked(),
            422,
            'El expediente aprobado está bloqueado.'
        );

        $validated = $request->validate([
            'document_type' => [
                'required',
                Rule::in($profile->requiredDocumentTypes()),
            ],
            'document' => [
                'required',
                'file',
                'mimes:pdf,jpg,jpeg,png,webp',
                'max:15360',
            ],
        ]);

        DB::connection('mysql_repartidor')->transaction(function () use (
            $request,
            $driver,
            $profile,
            $validated
        ): void {
            DriverIdentityDocument::query()
                ->where('identity_profile_id', $profile->id)
                ->where('document_type', $validated['document_type'])
                ->whereIn('status', ['pending', 'approved', 'rejected'])
                ->update([
                    'status' => 'replaced',
                ]);

            $file = $request->file('document');

            abort_unless($file !== null, 422, 'No se recibió el documento.');

            $path = $file->store(
                'repartidor/identity/'.
                $driver->id.'/'.
                $validated['document_type'],
                'local'
            );

            $document = DriverIdentityDocument::query()->create([
                'identity_profile_id' => $profile->id,
                'driver_user_id' => $driver->id,
                'document_type' => $validated['document_type'],
                'original_name' => $file->getClientOriginalName(),
                'path' => $path,
                'mime_type' => $file->getMimeType(),
                'size_bytes' => $file->getSize(),
                'sha256' => hash_file(
                    'sha256',
                    $file->getRealPath()
                ),
                'is_required' => true,
                'status' => 'pending',
            ]);

            $profile->forceFill([
                'status' => 'draft',
                'review_notes' => null,
                'submitted_at' => null,
                'review_started_at' => null,
                'approved_at' => null,
                'approved_by' => null,
                'rejected_at' => null,
                'rejected_by' => null,
                'identity_locked_at' => null,
                'identity_hash' => null,
            ])->save();

            $this->event(
                $profile,
                $request,
                'document_uploaded',
                'Documento del repartidor cargado.',
                [
                    'document_id' => $document->id,
                    'document_type' => $document->document_type,
                    'sha256' => $document->sha256,
                ]
            );
        });

        return back()
            ->with('status', 'Documento cargado correctamente.')
            ->with('active_tab', 'usuario');
    }

    public function submit(Request $request): RedirectResponse
    {
        $driver = $this->driver($request);
        $profile = $this->profile($driver)->load('documents');

        abort_if(
            $profile->status === 'approved',
            422,
            'El expediente ya está aprobado.'
        );

        $address = DriverAddress::query()
            ->where('driver_user_id', $driver->id)
            ->where('is_primary', true)
            ->where('is_active', true)
            ->first();

        $emergencyContact = DriverEmergencyContact::query()
            ->where('driver_user_id', $driver->id)
            ->first();

        $referenceCount = DriverPersonalReference::query()
            ->where('driver_user_id', $driver->id)
            ->count();

        abort_unless(
            $address !== null,
            422,
            'Debes registrar una dirección principal.'
        );

        abort_unless(
            $emergencyContact !== null,
            422,
            'Debes registrar un contacto de emergencia.'
        );

        abort_unless(
            $referenceCount >= 2,
            422,
            'Debes registrar dos referencias personales.'
        );

        abort_unless(
            $profile->isReadyForReview(),
            422,
            'Completa los datos personales, consentimientos y documentos obligatorios.'
        );

        $profile->forceFill([
            'status' => 'submitted',
            'submitted_at' => now(),
            'review_started_at' => null,
            'review_notes' => null,
        ])->save();

        $this->event(
            $profile,
            $request,
            'submitted',
            'Expediente del repartidor enviado a revisión.'
        );

        return back()
            ->with('status', 'Expediente enviado a revisión.')
            ->with('active_tab', 'usuario');
    }

    public function document(
        Request $request,
        DriverIdentityDocument $document
    ): StreamedResponse {
        $driver = $this->driver($request);

        abort_unless(
            (int) $document->driver_user_id === (int) $driver->id,
            404
        );

        abort_unless(
            Storage::disk('local')->exists($document->path),
            404
        );

        return Storage::disk('local')->response(
            $document->path,
            $document->original_name
        );
    }

    public function updateAvailability(Request $request): JsonResponse
    {
        $driver = $this->driver($request);

        $validated = $request->validate([
            'is_available' => ['required', 'boolean'],
        ]);

        if ($validated['is_available'] && ! $driver->isActive()) {
            return response()->json([
                'ok' => false,
                'message' => 'Tu cuenta debe estar activa y aprobada para conectarte.',
            ], 422);
        }

        $driver->forceFill([
            'is_available' => (bool) $validated['is_available'],
        ])->save();

        return response()->json([
            'ok' => true,
            'is_available' => $driver->is_available,
            'label' => $driver->is_available
                ? 'Disponible'
                : 'No disponible',
        ]);
    }

    private function driver(Request $request): DriverUser
    {
        $driver = $request->user('repartidor');

        abort_unless($driver instanceof DriverUser, 401);

        return $driver;
    }

    private function profile(DriverUser $driver): DriverIdentityProfile
    {
        return DriverIdentityProfile::query()->firstOrCreate(
            [
                'driver_user_id' => $driver->id,
            ],
            [
                'uuid' => (string) Str::uuid(),
                'paternal_last_name' => $driver->last_name,
                'mobile_phone' => $driver->phone,
                'contact_email' => $driver->email,
                'status' => 'draft',
                'liveness_challenge' => 'Toma una selfie mostrando tu rostro y una hoja con la fecha actual y la palabra PETPAY.',
            ]
        );
    }

    private function event(
        DriverIdentityProfile $profile,
        Request $request,
        string $type,
        string $description,
        array $metadata = []
    ): void {
        DriverIdentityEvent::query()->create([
            'identity_profile_id' => $profile->id,
            'driver_user_id' => $profile->driver_user_id,
            'event_type' => $type,
            'actor_type' => 'driver',
            'actor_id' => $profile->driver_user_id,
            'description' => $description,
            'metadata' => $metadata,
            'ip_address' => $request->ip(),
            'user_agent' => (string) $request->userAgent(),
            'occurred_at' => now(),
        ]);
    }


    private function normalizeMexicanPhone(string $phone): string
    {
        $digits = preg_replace('/\D+/', '', $phone) ?? '';

        if (str_starts_with($digits, '52') && strlen($digits) === 12) {
            $digits = substr($digits, 2);
        }

        if (strlen($digits) !== 10) {
            abort(422, 'Los teléfonos deben contener exactamente 10 dígitos.');
        }

        return '+52'.$digits;
    }

    private function maskPhone(string $phone): string
    {
        $digits = preg_replace('/\D+/', '', $phone) ?? '';

        return '******'.substr($digits, -4);
    }

    private function normalizeComparableName(string $value): string
    {
        return Str::lower(
            Str::ascii(
                trim(preg_replace('/\s+/', ' ', $value) ?? $value)
            )
        );
    }

