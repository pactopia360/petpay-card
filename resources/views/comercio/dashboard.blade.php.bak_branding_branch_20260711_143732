                    return;
                }

                // Movimiento visible aproximado: 12 metros por clic.
                const meters = 12;
                const latStep = meters / 111320;
                const lngStep = meters / (111320 * Math.cos(current.lat * Math.PI / 180) || 1);
                let nextLat = current.lat;
                let nextLng = current.lng;

                if (direction === 'north') nextLat += latStep;
                if (direction === 'south') nextLat -= latStep;
                if (direction === 'east') nextLng += lngStep;
                if (direction === 'west') nextLng -= lngStep;

                setCoordinatesFromLatLng(nextLat, nextLng, 'Ubicación movida con flechas. Coordenadas actualizadas.');

                const next = extractCoordinatesObject(fields.google_coordinates.value);
