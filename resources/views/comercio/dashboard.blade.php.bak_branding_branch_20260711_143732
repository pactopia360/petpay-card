                const atMatch = decoded.match(/@(-?\d+(?:\.\d+)?),\s*(-?\d+(?:\.\d+)?)/);
                const plainMatch = decoded.match(/(-?\d+(?:\.\d+)?)\s*[,;]\s*(-?\d+(?:\.\d+)?)/);
                const match = atMatch || plainMatch;

                if (!match) {
                    return null;
                }

                const lat = Number(match[1]);
                const lng = Number(match[2]);

                if (Number.isNaN(lat) || Number.isNaN(lng) || lat < -90 || lat > 90 || lng < -180 || lng > 180) {
                    return null;
                }

                return `${lat.toFixed(6)}, ${lng.toFixed(6)}`;
            };

            const extractCoordinatesObject = (value) => {
                const coordinates = extractCoordinates(value);

                if (!coordinates) {
                    return null;
                }

                const [lat, lng] = coordinates.split(',').map((part) => Number(part.trim()));

                if (Number.isNaN(lat) || Number.isNaN(lng)) {
                    return null;
                }

                return { lat, lng };
            };

            const formatCoordinates = (lat, lng) => `${Number(lat).toFixed(6)}, ${Number(lng).toFixed(6)}`;

            const createGoogleMapsEmbedUrl = (query, zoom = 18) => {
                return `https://maps.google.com/maps?q=${encodeURIComponent(query)}&z=${zoom}&output=embed`;
            };

            const clampCoordinate = (value, min, max) => Math.min(max, Math.max(min, Number(value)));

            const applyLatLngToBranch = (lat, lng, message = 'Ubicación ajustada. Guarda la sucursal para conservar estas coordenadas.') => {
                const nextLat = clampCoordinate(lat, -90, 90);
                const nextLng = clampCoordinate(lng, -180, 180);
                fields.google_coordinates.value = formatCoordinates(nextLat, nextLng);
                previewCoordinates.textContent = fields.google_coordinates.value;
                setCoordinatesHint(message, true);
                updateStatus();
                renderGoogleLinks(fields.google_coordinates.value);
                renderSideMap(fields.google_coordinates.value);
            };

            const setCoordinatesFromLatLng = (lat, lng, message = 'Ubicación ajustada. Guarda la sucursal para conservar estas coordenadas.') => {
                applyLatLngToBranch(lat, lng, message);
            };

            const loadGoogleMapsSdk = () => {
                if (!googleMapsBrowserKey) {
                    return Promise.reject(new Error('missing-google-maps-key'));
                }

                if (window.google?.maps) {
                    return Promise.resolve(window.google.maps);
                }

                if (googleMapsLoaderPromise) {
                    return googleMapsLoaderPromise;
                }

                googleMapsLoaderPromise = new Promise((resolve, reject) => {
                    const callbackName = `petpayGoogleMapsReady${Date.now()}`;
                    window[callbackName] = () => {
                        delete window[callbackName];
                        resolve(window.google.maps);
                    };

                    const script = document.createElement('script');
                    script.src = `https://maps.googleapis.com/maps/api/js?key=${encodeURIComponent(googleMapsBrowserKey)}&callback=${callbackName}`;
                    script.async = true;
                    script.defer = true;
                    script.onerror = () => {
                        delete window[callbackName];
                        googleMapsLoaderPromise = null;
                        reject(new Error('google-maps-load-error'));
                    };
                    document.head.appendChild(script);
                });

                return googleMapsLoaderPromise;
            };

            const initFallbackDraggableMap = (lat, lng) => {
                if (!inlineMapPreview) {
                    return false;
                }

                const position = { lat: Number(lat), lng: Number(lng) };

                if (Number.isNaN(position.lat) || Number.isNaN(position.lng)) {
                    return false;
                }

                inlineMapPreview.classList.add('is-interactive');
                inlineMapPreview.innerHTML = `
                    <div class="commerce-location-panel__drag-map" id="branchFallbackDragMap">
                        <iframe title="Google Maps sucursal" loading="lazy" referrerpolicy="no-referrer-when-downgrade" src="${createGoogleMapsEmbedUrl(formatCoordinates(position.lat, position.lng), branchMapZoom)}"></iframe>
                        <div class="commerce-location-panel__drag-crosshair" aria-hidden="true"></div>
                        <button type="button" class="commerce-location-panel__drag-pin" id="branchFallbackDragPin" aria-label="Mover pin de ubicación"></button>
                        <div class="commerce-location-panel__drag-help">Arrastra el pin rojo o da clic sobre el mapa para ajustar la ubicación exacta. El mapa base es Google Maps; guarda cuando las coordenadas queden correctas.</div>
                    </div>
                `;

                const mapNode = document.getElementById('branchFallbackDragMap');
                const pinNode = document.getElementById('branchFallbackDragPin');

                if (!mapNode || !pinNode) {
                    return false;
                }

                let current = { ...position };
                let dragBase = { ...position };
                let isDragging = false;

                const setPinFromPoint = (clientX, clientY, message, basePosition = current, shouldReverse = true) => {
                    const rect = mapNode.getBoundingClientRect();
                    const x = Math.min(rect.width, Math.max(0, clientX - rect.left));
                    const y = Math.min(rect.height, Math.max(0, clientY - rect.top));

                    pinNode.style.left = `${x}px`;
                    pinNode.style.top = `${y}px`;

                    const dx = x - (rect.width / 2);
                    const dy = y - (rect.height / 2);
                    const metersPerPixel = 0.55;
                    const metersNorth = -dy * metersPerPixel;
                    const metersEast = dx * metersPerPixel;
                    const latOffset = metersNorth / 111320;
                    const lngOffset = metersEast / (111320 * Math.cos(basePosition.lat * Math.PI / 180) || 1);

                    applyLatLngToBranch(basePosition.lat + latOffset, basePosition.lng + lngOffset, message);
                    current = extractCoordinatesObject(fields.google_coordinates.value) || current;
                    if (shouldReverse) {
                        refreshAddressFromCurrentCoordinates(true, 'Dirección actualizada con la ubicación marcada.');
                    }
                };

                const startDrag = (event) => {
                    isDragging = true;
                    dragBase = extractCoordinatesObject(fields.google_coordinates.value) || current;
                    pinNode.setPointerCapture?.(event.pointerId);
                    event.preventDefault();
                };

                const moveDrag = (event) => {
                    if (!isDragging) {
                        return;
                    }
                    setPinFromPoint(event.clientX, event.clientY, 'Pin movido. Coordenadas actualizadas.', dragBase, false);
                };

                const stopDrag = (event) => {
                    if (!isDragging) {
                        return;
                    }
                    isDragging = false;
                    pinNode.releasePointerCapture?.(event.pointerId);
                    refreshAddressFromCurrentCoordinates(true, 'Dirección actualizada con el pin.');
                };

                pinNode.addEventListener('pointerdown', startDrag);
                pinNode.addEventListener('pointermove', moveDrag);
                pinNode.addEventListener('pointerup', stopDrag);
                pinNode.addEventListener('pointercancel', stopDrag);
                mapNode.addEventListener('click', (event) => {
                    if (event.target === pinNode) {
                        return;
                    }
                    dragBase = extractCoordinatesObject(fields.google_coordinates.value) || current;
                    setPinFromPoint(event.clientX, event.clientY, 'Ubicación ajustada desde el mapa.', dragBase, true);
                });

                return true;
            };

            const initDraggableGoogleMap = async (lat, lng) => {
                if (!inlineMapPreview) {
                    return false;
                }

                try {
                    await loadGoogleMapsSdk();
                } catch (error) {
                    return false;
                }

                inlineMapPreview.classList.add('is-interactive');
                inlineMapPreview.innerHTML = '<div id="branchGoogleInteractiveMap" class="commerce-location-panel__interactive-map"></div><div class="commerce-location-panel__map-tip">Arrastra el pin o da clic en el mapa para ajustar la ubicación exacta.</div>';

                const mapNode = document.getElementById('branchGoogleInteractiveMap');
                const position = { lat: Number(lat), lng: Number(lng) };

                branchInteractiveMap = new google.maps.Map(mapNode, {
                    center: position,
                    zoom: branchMapZoom,
                    mapTypeControl: false,
                    streetViewControl: true,
                    fullscreenControl: true,
                });

                branchInteractiveMarker = new google.maps.Marker({
                    position,
                    map: branchInteractiveMap,
                    draggable: true,
                    title: 'Ubicación de la sucursal',
                });

                const applyPosition = (latLng) => {
                    const nextLat = typeof latLng.lat === 'function' ? latLng.lat() : latLng.lat;
                    const nextLng = typeof latLng.lng === 'function' ? latLng.lng() : latLng.lng;
                    branchInteractiveMarker.setPosition({ lat: nextLat, lng: nextLng });
                    branchInteractiveMap.panTo({ lat: nextLat, lng: nextLng });
                    applyLatLngToBranch(nextLat, nextLng, 'Pin movido. Coordenadas actualizadas.');
                    refreshAddressFromCurrentCoordinates(true, 'Dirección actualizada con la ubicación marcada.');
                };

                branchInteractiveMarker.addListener('dragend', (event) => applyPosition(event.latLng));
                branchInteractiveMap.addListener('click', (event) => applyPosition(event.latLng));

                return true;
            };

            const geocodeQueryWithGoogle = async (query) => {
                try {
                    await loadGoogleMapsSdk();
                } catch (error) {
                    return null;
                }

                return new Promise((resolve) => {
                    const geocoder = new google.maps.Geocoder();
                    geocoder.geocode({ address: query }, (results, status) => {
                        if (status !== 'OK' || !results?.[0]?.geometry?.location) {
                            resolve(null);
                            return;
                        }

                        const location = results[0].geometry.location;
                        resolve({ lat: location.lat(), lng: location.lng() });
                    });
                });
            };

            const getGoogleMapsQuery = () => {
                const coordinates = extractCoordinates(fields.google_coordinates.value);

                if (coordinates) {
                    return coordinates;
                }

                const search = locationSearchInput?.value.trim();

                if (search) {
                    return search;
                }

                const address = getAddressParts().join(', ');

                if (address && address !== 'México') {
                    return address;
                }

                return '';
            };

            const getAddressQuery = () => getAddressParts().join(', ');

            const setCoordinatesHint = (message, valid = null) => {
                if (!branchCoordinatesHint) {
                    return;
                }

                branchCoordinatesHint.textContent = message;
                branchCoordinatesHint.classList.toggle('is-valid', valid === true);
                branchCoordinatesHint.classList.toggle('is-invalid', valid === false);
            };


            const stateAliases = {
                'cdmx': 'ciudad_de_mexico',
                'ciudad de mexico': 'ciudad_de_mexico',
                'ciudad de méxico': 'ciudad_de_mexico',
                'mexico city': 'ciudad_de_mexico',
                'estado de mexico': 'estado_de_mexico',
                'estado de méxico': 'estado_de_mexico',
                'edomex': 'estado_de_mexico',
                'nuevo leon': 'nuevo_leon',
                'nuevo león': 'nuevo_leon',
                'san luis potosi': 'san_luis_potosi',
                'san luis potosí': 'san_luis_potosi',
                'michoacan': 'michoacan',
                'michoacán': 'michoacan',
                'queretaro': 'queretaro',
                'querétaro': 'queretaro',
                'yucatan': 'yucatan',
                'yucatán': 'yucatan'
            };

            const normalizeStateKey = (value) => {
                const raw = String(value || '').trim();
                if (!raw) return '';
                const normalized = raw.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase().replace(/[^a-z0-9]+/g, ' ').trim();
                const alias = stateAliases[raw.toLowerCase()] || stateAliases[normalized];
                if (alias) return alias;
                const key = normalized.replace(/\s+/g, '_');
                const exists = Array.from(fields.state.options).some((option) => option.value === key);
                return exists ? key : '';
            };

            const putFieldValue = (field, value, overwrite = false) => {
                if (!field || value === null || value === undefined) return false;
                const clean = String(value).trim();
                if (!clean) return false;
                if (!overwrite && String(field.value || '').trim()) return false;
                field.value = clean;
                field.dispatchEvent(new Event('input', { bubbles: true }));
                field.dispatchEvent(new Event('change', { bubbles: true }));
                return true;
            };

            const applyAddressPayload = (payload = {}, overwrite = false) => {
                let changed = false;
                const streetLine = [payload.street, payload.number].filter(Boolean).join(' ').trim() || payload.road || '';
                changed = putFieldValue(fields.street, streetLine, overwrite) || changed;
                changed = putFieldValue(fields.neighborhood, payload.neighborhood || payload.suburb || payload.colony || '', overwrite) || changed;
                changed = putFieldValue(fields.postal_code, payload.postal_code || payload.postcode || '', overwrite) || changed;

                const stateKey = normalizeStateKey(payload.state || payload.region || payload.administrative_area_level_1 || '');
                if (stateKey && (overwrite || !fields.state.value)) {
                    fields.state.value = stateKey;
                    fields.state.dispatchEvent(new Event('change', { bubbles: true }));
                    changed = true;
                }

                if (changed) {
                    updateStatus();
                }

                return changed;
            };

            const reverseFillAddressWithGoogle = async (lat, lng, overwrite = false) => {
                try {
                    await loadGoogleMapsSdk();
                } catch (error) {
                    return false;
                }

                return new Promise((resolve) => {
                    const geocoder = new google.maps.Geocoder();
                    geocoder.geocode({ location: { lat: Number(lat), lng: Number(lng) } }, (results, status) => {
                        if (status !== 'OK' || !results?.[0]) {
                            resolve(false);
                            return;
                        }

                        const components = results[0].address_components || [];
                        const get = (type) => components.find((component) => component.types.includes(type))?.long_name || '';
                        const payload = {
                            street: get('route'),
                            number: get('street_number'),
                            neighborhood: get('sublocality_level_1') || get('neighborhood') || get('political'),
                            postal_code: get('postal_code'),
                            state: get('administrative_area_level_1')
                        };

                        resolve(applyAddressPayload(payload, overwrite));
                    });
                });
            };

            const reverseFillAddressWithOpenStreetMap = async (lat, lng, overwrite = false) => {
                try {
                    const url = `https://nominatim.openstreetmap.org/reverse?format=jsonv2&lat=${encodeURIComponent(lat)}&lon=${encodeURIComponent(lng)}&zoom=18&addressdetails=1`;
                    const response = await fetch(url, { headers: { Accept: 'application/json' } });
                    if (!response.ok) return false;
                    const data = await response.json();
                    const address = data.address || {};
                    const payload = {
                        street: address.road || address.pedestrian || address.footway || address.neighbourhood || '',
                        number: address.house_number || '',
                        neighborhood: address.neighbourhood || address.suburb || address.city_district || address.quarter || '',
                        postal_code: address.postcode || '',
                        state: address.state || address.region || ''
                    };
                    return applyAddressPayload(payload, overwrite);
                } catch (error) {
                    return false;
                }
            };

            const reverseFillAddressWithBigDataCloud = async (lat, lng, overwrite = false) => {
                try {
                    const url = `https://api.bigdatacloud.net/data/reverse-geocode-client?latitude=${encodeURIComponent(lat)}&longitude=${encodeURIComponent(lng)}&localityLanguage=es`;
                    const response = await fetch(url, { headers: { Accept: 'application/json' } });
                    if (!response.ok) return false;
                    const data = await response.json();
                    const payload = {
                        street: data.locality || data.city || '',
                        number: '',
                        neighborhood: data.locality || data.city || '',
                        postal_code: data.postcode || '',
                        state: data.principalSubdivision || data.localityInfo?.administrative?.find?.((item) => item.adminLevel === 4)?.name || ''
                    };
                    return applyAddressPayload(payload, overwrite);
                } catch (error) {
                    return false;
                }
            };

            const reverseFillAddressFromCoordinates = async (lat, lng, overwrite = false) => {
                setCoordinatesHint('GPS detectado. Buscando dirección de la sucursal...', null);
                const googleReady = googleMapsBrowserKey
                    ? await reverseFillAddressWithGoogle(lat, lng, overwrite)
                    : false;
                let fallbackReady = googleReady ? true : await reverseFillAddressWithOpenStreetMap(lat, lng, overwrite);

                if (!fallbackReady) {
                    fallbackReady = await reverseFillAddressWithBigDataCloud(lat, lng, overwrite);
                }

                if (fallbackReady) {
                    setCoordinatesHint('Ubicación detectada y dirección sugerida. Revisa que corresponda a la sucursal.', true);
                    updateStatus();
                    return true;
                }

                setCoordinatesHint('GPS detectado. No se pudo autollenar la dirección; captura calle, colonia, CP y estado.', true);
                return false;
            };

            const renderGoogleLinks = (query) => {
                const googleUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(query)}`;

                [branchOpenGoogleMaps, branchInlineOpenGoogleMaps].forEach((link) => {
                    if (!link) return;
                    link.href = googleUrl;
                    link.classList.remove('is-disabled');
                });
            };

            const renderSideMap = (query) => {
                if (!mapPreview) {
                    return;
                }

                const embedUrl = createGoogleMapsEmbedUrl(query, branchMapZoom);
                mapPreview.classList.add('has-coordinates');
                mapPreview.innerHTML = `<iframe title="Google Maps sucursal" loading="lazy" referrerpolicy="no-referrer-when-downgrade" src="${embedUrl}"></iframe>`;
            };

            const renderIframeMap = (query) => {
                const embedUrl = createGoogleMapsEmbedUrl(query, branchMapZoom);
                const iframe = `<iframe title="Google Maps sucursal" loading="lazy" referrerpolicy="no-referrer-when-downgrade" src="${embedUrl}"></iframe>`;

                if (inlineMapPreview) {
                    inlineMapPreview.classList.remove('is-interactive');
                    inlineMapPreview.innerHTML = iframe;
                }
            };

            const setInlineMapLoading = (isLoading) => {
                if (!inlineMapPreview) {
                    return;
                }

                inlineMapPreview.classList.toggle('is-loading', Boolean(isLoading));
            };

            const forceRenderCoordinatesMap = (lat, lng, message = 'Ubicación detectada. Revisa que corresponda a la sucursal.') => {
                const coordinates = formatCoordinates(lat, lng);
                fields.google_coordinates.value = coordinates;
                if (locationSearchInput) {
                    locationSearchInput.value = `GPS actual ${coordinates}`;
                }

                renderSideMap(coordinates);
                renderGoogleLinks(coordinates);

                if (googleMapsBrowserKey) {
                    setInlineMapLoading(true);
                    initDraggableGoogleMap(lat, lng)
                        .catch(() => false)
                        .then((ready) => {
                            if (!ready) {
                                initFallbackDraggableMap(lat, lng);
                            }
                            setInlineMapLoading(false);
                        });
                } else {
                    initFallbackDraggableMap(lat, lng);
                }

                if (previewCoordinates) {
                    previewCoordinates.textContent = coordinates;
                }

                setCoordinatesHint(message, true);
                updateStatus();
            };

            const renderGoogleMap = async () => {
                let query = getGoogleMapsQuery();
                let coordinatesObject = extractCoordinatesObject(fields.google_coordinates.value);

                if (!query) {
                    if (mapPreview) {
                        mapPreview.classList.remove('has-coordinates');
                        mapPreview.innerHTML = '<div class="commerce-map-card__placeholder">Agrega coordenadas o dirección para cargar Google Maps</div>';
                    }

                    if (inlineMapPreview) {
                        inlineMapPreview.classList.remove('is-interactive', 'is-loading');
                        inlineMapPreview.innerHTML = '<div class="commerce-location-panel__map-placeholder">Busca la dirección o usa GPS para ver la sucursal en Google Maps</div>';
                    }

                    previewCoordinates.textContent = 'Sin coordenadas';

                    [branchOpenGoogleMaps, branchInlineOpenGoogleMaps].forEach((link) => {
                        if (!link) return;
                        link.href = '#';
                        link.classList.add('is-disabled');
                    });

                    setCoordinatesHint('Pega coordenadas, enlace de Google Maps, busca por dirección o usa GPS.', null);
                    return;
                }

                renderSideMap(query);
                renderGoogleLinks(query);

                if (!coordinatesObject && googleMapsBrowserKey) {
                    setCoordinatesHint('Buscando coordenadas reales con Google Maps...', null);
                    const geocoded = await geocodeQueryWithGoogle(query);

                    if (geocoded) {
                        setCoordinatesFromLatLng(geocoded.lat, geocoded.lng, 'Dirección localizada. Ahora puedes arrastrar el pin para dejarla exacta.');
                        reverseFillAddressFromCoordinates(geocoded.lat, geocoded.lng, false);
                        coordinatesObject = geocoded;
                        query = fields.google_coordinates.value;
                        renderSideMap(query);
                        renderGoogleLinks(query);
                    }
                }

                if (coordinatesObject) {
                    let interactiveReady = false;

                    setInlineMapLoading(true);
                    if (googleMapsBrowserKey) {
                        interactiveReady = await initDraggableGoogleMap(coordinatesObject.lat, coordinatesObject.lng);
                    }

                    if (!interactiveReady) {
                        interactiveReady = initFallbackDraggableMap(coordinatesObject.lat, coordinatesObject.lng);
                    }
                    setInlineMapLoading(false);

                    if (interactiveReady) {
                        previewCoordinates.textContent = fields.google_coordinates.value;
                        setCoordinatesHint(
                            googleMapsBrowserKey
                                ? 'Arrastra el pin o da clic en el mapa para ajustar la ubicación exacta.'
                                : 'Arrastra el pin rojo sobre el mapa para ajustar la ubicación. Para Google Maps interactivo completo configura GOOGLE_MAPS_BROWSER_KEY.',
                            true
                        );
                        return;
                    }
                }

                setInlineMapLoading(false);
                renderIframeMap(query);
                previewCoordinates.textContent = extractCoordinates(fields.google_coordinates.value) || query;
                setCoordinatesHint(
                    coordinatesObject
                        ? 'Coordenadas listas. Puedes ajustar con las flechas o activar GOOGLE_MAPS_BROWSER_KEY para mapa completo.'
                        : 'Mapa generado por búsqueda/dirección. Para mover el punto exacto usa GPS o pega coordenadas.',
                    true
                );
            };

            const refreshAddressFromCurrentCoordinates = async (overwrite = true, successMessage = 'Dirección actualizada con la ubicación actual.') => {
                const current = extractCoordinatesObject(fields.google_coordinates.value);

                if (!current) {
                    setCoordinatesHint('Primero selecciona una ubicación, usa GPS o pega coordenadas para leer la dirección.', false);
                    return false;
                }

                const ready = await reverseFillAddressFromCoordinates(current.lat, current.lng, overwrite);

                if (ready && successMessage) {
                    setCoordinatesHint(successMessage, true);
                }

                renderSideMap(fields.google_coordinates.value);
                renderGoogleLinks(fields.google_coordinates.value);
                updateStatus();

                return ready;
            };

            const setBranchMapZoom = (delta) => {
                branchMapZoom = Math.max(12, Math.min(21, branchMapZoom + delta));

                if (branchInteractiveMap) {
                    branchInteractiveMap.setZoom(branchMapZoom);
                }

                const current = extractCoordinatesObject(fields.google_coordinates.value);
                const query = current ? formatCoordinates(current.lat, current.lng) : getGoogleMapsQuery();

                if (query) {
                    renderSideMap(query);

                    if (!branchInteractiveMap && current) {
                        initFallbackDraggableMap(current.lat, current.lng);
                    } else if (!branchInteractiveMap) {
                        renderIframeMap(query);
                    }
                }

                setCoordinatesHint(branchMapZoom > 18 ? 'Mapa acercado. Ajusta el pin y actualiza la dirección.' : 'Mapa alejado. Ajusta el pin y actualiza la dirección.', true);
            };

            const updateStatus = () => {
                const missing = getMissingFields();

                statusFlag.classList.toggle('is-green', missing.length === 0);
                statusFlag.classList.toggle('is-red', missing.length > 0);
                statusFlag.classList.toggle('is-warning', false);

                statusText.textContent = missing.length === 0
                    ? 'Bandera verde: información completa'
                    : `Faltan ${missing.length} datos`;

                missingPreview.textContent = missing.length === 0
                    ? 'Todo está completo. La sucursal puede operar con bandera verde.'
                    : `Falta: ${missing.join(', ')}.`;

                previewName.textContent = fields.branch_name.value.trim() || 'Nueva sucursal';

                const addressParts = getAddressParts().filter((part) => part !== 'México');

                previewAddress.textContent = addressParts.length > 0
                    ? addressParts.join(', ')
                    : 'Ingresa dirección y coordenadas para previsualizar.';

                previewCoordinates.textContent = extractCoordinates(fields.google_coordinates.value)
                    || fields.google_coordinates.value.trim()
                    || 'Sin coordenadas';
            };

            const openMapPreview = async () => {
                updateStatus();
                await renderGoogleMap();
            };

            if (mapPreviewButton) {
                mapPreviewButton.addEventListener('click', openMapPreview);
            }

            if (branchRefreshMapButton) {
                branchRefreshMapButton.addEventListener('click', async (event) => {
                    event.preventDefault();
                    const current = extractCoordinatesObject(fields.google_coordinates.value);
                    if (current) {
                        forceRenderCoordinatesMap(current.lat, current.lng, 'Mapa actualizado con las coordenadas actuales. Leyendo dirección...');
                        await refreshAddressFromCurrentCoordinates(true, 'Dirección actualizada con las coordenadas actuales.');
                        return;
                    }
                    await openMapPreview();
                    await refreshAddressFromCurrentCoordinates(true, 'Dirección actualizada con la ubicación actual.');
                });
            }

            if (branchMapBiggerButton) {
                branchMapBiggerButton.addEventListener('click', (event) => {
                    event.preventDefault();
                    setBranchMapZoom(1);
                });
            }

            if (branchMapSmallerButton) {
                branchMapSmallerButton.addEventListener('click', (event) => {
                    event.preventDefault();
                    setBranchMapZoom(-1);
                });
            }

            if (branchFillSearchFromAddressButton) {
