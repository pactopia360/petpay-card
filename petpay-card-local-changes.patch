@@ -0,0 +1,911 @@
+/* =========================================================
+   PETPAY-CARD | CLIENTE MARKETPLACE
+   Dashboard tipo marketplace / Amazon inspirado en Petpay
+========================================================= */
+
+:root {
+    --petpay-client-orange: #ff7a00;
+    --petpay-client-orange-dark: #f05f00;
+    --petpay-client-coral: #ff4d61;
+    --petpay-client-cream: #fff8ef;
+    --petpay-client-cream-2: #fff1df;
+    --petpay-client-white: #ffffff;
+    --petpay-client-black: #111827;
+    --petpay-client-muted: #6b7280;
+    --petpay-client-line: rgba(17, 24, 39, 0.08);
+    --petpay-client-shadow: 0 18px 50px rgba(17, 24, 39, 0.08);
+    --petpay-client-shadow-soft: 0 10px 28px rgba(17, 24, 39, 0.06);
+}
+
+body {
+    background:
+        radial-gradient(circle at 16% 10%, rgba(255, 122, 0, 0.10), transparent 24%),
+        radial-gradient(circle at 88% 20%, rgba(255, 77, 97, 0.10), transparent 22%),
+        #fffaf4;
+}
+
+.petpay-client-market {
+    min-height: calc(100vh - 74px);
+    display: grid;
+    grid-template-columns: 84px minmax(0, 1fr);
+    gap: 0;
+    background:
+        linear-gradient(135deg, rgba(255, 122, 0, 0.06), transparent 36%),
+        linear-gradient(315deg, rgba(255, 77, 97, 0.055), transparent 34%),
+        #fffaf4;
+    color: var(--petpay-client-black);
+}
+
+/* =========================================================
+   MAIN
+========================================================= */
+
+.petpay-client-market__main {
+    min-width: 0;
+    padding: 22px 24px 34px;
+}
+
+.petpay-client-market__hero-head {
+    display: flex;
+    align-items: center;
+    justify-content: space-between;
+    gap: 18px;
+    margin-bottom: 16px;
+}
+
+.petpay-client-market__hello {
+    display: flex;
+    align-items: center;
+    gap: 12px;
+}
+
+.petpay-client-market__paw {
+    width: 48px;
+    height: 48px;
+    border-radius: 18px;
+    display: inline-flex;
+    align-items: center;
+    justify-content: center;
+    background:
+        radial-gradient(circle at 35% 30%, rgba(255, 255, 255, 0.85), transparent 32%),
+        linear-gradient(135deg, #ff9f2f, #ff6b00);
+    color: #ffffff;
+    font-size: 28px;
+    box-shadow: 0 14px 30px rgba(255, 111, 0, 0.25);
+}
+
+.petpay-client-market__eyebrow {
+    margin: 0 0 3px;
+    font-size: 11px;
+    line-height: 1;
+    font-weight: 950;
+    letter-spacing: 0.14em;
+    text-transform: uppercase;
+    color: var(--petpay-client-orange);
+}
+
+.petpay-client-market__hello h1 {
+    margin: 0;
+    font-size: 28px;
+    line-height: 1.05;
+    letter-spacing: -0.05em;
+    font-weight: 950;
+}
+
+.petpay-client-market__hello p {
+    margin: 5px 0 0;
+    font-size: 13px;
+    line-height: 1.35;
+    color: var(--petpay-client-muted);
+}
+
+.petpay-client-market__quick-actions {
+    display: flex;
+    align-items: center;
+    gap: 10px;
+}
+
+.petpay-client-market__quick-btn {
+    min-height: 42px;
+    padding: 0 15px;
+    border-radius: 15px;
+    display: inline-flex;
+    align-items: center;
+    justify-content: center;
+    gap: 7px;
+    background: rgba(255, 255, 255, 0.86);
+    border: 1px solid rgba(17, 24, 39, 0.07);
+    box-shadow: var(--petpay-client-shadow-soft);
+    color: #172033;
+    font-size: 13px;
+    font-weight: 900;
+    white-space: nowrap;
+}
+
+.petpay-client-market__quick-btn span {
+    min-width: 22px;
+    height: 22px;
+    padding: 0 7px;
+    border-radius: 999px;
+    display: inline-flex;
+    align-items: center;
+    justify-content: center;
+    background: var(--petpay-client-orange);
+    color: #ffffff;
+    font-size: 11px;
+}
+
+.petpay-client-market__quick-btn--orange {
+    background: linear-gradient(135deg, #ff8a18, #ff6b00);
+    color: #ffffff;
+    border-color: transparent;
+    box-shadow: 0 16px 34px rgba(255, 106, 0, 0.22);
+}
+
+.petpay-client-market__quick-btn--orange span {
+    background: rgba(255, 255, 255, 0.22);
+}
+
+/* =========================================================
+   LAYOUT
+========================================================= */
+
+.petpay-client-market__layout {
+    display: grid;
+    grid-template-columns: minmax(0, 1fr) 320px;
+    gap: 20px;
+    align-items: start;
+}
+
+.petpay-client-market__content {
+    min-width: 0;
+    display: grid;
+    gap: 16px;
+}
+
+.petpay-client-market__aside {
+    min-width: 0;
+    display: grid;
+    gap: 16px;
+}
+
+/* =========================================================
+   SEARCH
+========================================================= */
+
+.petpay-client-market__search {
+    padding: 13px;
+    border-radius: 22px;
+    display: grid;
+    grid-template-columns: 310px minmax(0, 1fr);
+    gap: 12px;
+    background: rgba(255, 255, 255, 0.88);
+    border: 1px solid rgba(17, 24, 39, 0.07);
+    box-shadow: var(--petpay-client-shadow);
+    backdrop-filter: blur(12px);
+    -webkit-backdrop-filter: blur(12px);
+}
+
+.petpay-client-market__search-box {
+    min-width: 0;
+}
+
+.petpay-client-market__search-box label {
+    display: block;
+    margin: 0 0 6px;
+    font-size: 11px;
+    line-height: 1;
+    font-weight: 950;
+    color: #172033;
+}
+
+.petpay-client-market__search-box select,
+.petpay-client-market__search-box input {
+    width: 100%;
+    height: 40px;
+    border: 1px solid rgba(17, 24, 39, 0.10);
+    outline: none;
+    border-radius: 13px;
+    padding: 0 13px;
+    background: #ffffff;
+    color: #172033;
+    font-size: 13px;
+}
+
+.petpay-client-market__search-box small {
+    display: inline-flex;
+    margin-top: 6px;
+    color: #16a34a;
+    font-size: 11px;
+    font-weight: 900;
+}
+
+.petpay-client-market__search-inline {
+    display: grid;
+    grid-template-columns: minmax(0, 1fr) 94px;
+    gap: 0;
+}
+
+.petpay-client-market__search-inline input {
+    border-radius: 13px 0 0 13px;
+    border-right: 0;
+}
+
+.petpay-client-market__search-inline button {
